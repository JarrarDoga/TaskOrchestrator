@page "/teams"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager Nav

@using System.Net.Http.Json
@using TaskOrchestrator.Shared.Contracts

<PageTitle>Orchestrator - Teams</PageTitle>

<div class="flex flex-col h-full overflow-y-auto">
    <div class="flex items-end justify-between px-10 pt-10 pb-6">
        <div>
            <h1 class="text-4xl font-headline font-extrabold text-on-surface tracking-tight mb-1">Active Teams</h1>
            <p class="text-on-surface-variant font-body">Manage ownership, members, and team-level boards.</p>
        </div>
        <button @onclick="() => _showCreate = true"
                class="btn-gradient text-white px-6 py-3 rounded-xl font-headline font-bold flex items-center gap-2 hover:opacity-90 active:scale-95 transition-all shadow-lg shadow-primary/20">
            <span class="material-symbols-outlined text-lg">group_add</span>
            Create Team
        </button>
    </div>

    <div class="px-10">
        @if (_loading)
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @for (var i = 0; i < 3; i++)
                {
                    <div class="h-52 rounded-xl bg-surface-container-high animate-pulse"></div>
                }
            </div>
        }
        else if (_teams.Count == 0)
        {
            <div class="rounded-xl bg-surface-container-low border border-outline-variant/20 p-10 text-center">
                <p class="text-on-surface-variant text-sm">No teams yet. Create one to organize boards by ownership and access.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var team in _teams)
                {
                    var t = team;
                    <div class="group relative bg-surface-container-low rounded-xl p-6 transition-all duration-300
                                hover:bg-surface-bright border border-white/5 hover:border-primary/40 shadow-2xl shadow-black/20 cursor-pointer"
                         @onclick="() => OpenTeam(t)">
                        <div class="flex justify-between items-start mb-6">
                            <div class="flex items-center gap-4 min-w-0">
                                <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                                    <span class="material-symbols-outlined text-3xl">@t.Icon</span>
                                </div>
                                <div class="min-w-0">
                                    <h3 class="font-headline font-bold text-lg text-on-surface truncate">@t.Name</h3>
                                    <p class="text-xs text-on-surface-variant font-medium truncate">@t.Slug</p>
                                </div>
                            </div>
                            <button @onclick="() => DeleteTeam(t)" @onclick:stopPropagation
                                    class="material-symbols-outlined text-on-surface-variant group-hover:text-error hover:text-error transition-colors cursor-pointer">
                                delete
                            </button>
                        </div>

                        <div class="grid grid-cols-2 gap-3 mb-6">
                            <div class="bg-surface-container-highest/40 rounded-lg p-3">
                                <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-wider block mb-1">Members</span>
                                <span class="text-lg font-bold font-headline text-on-surface">@t.MemberCount</span>
                            </div>
                            <div class="bg-surface-container-highest/40 rounded-lg p-3">
                                <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-wider block mb-1">Boards</span>
                                <span class="text-lg font-bold font-headline text-on-surface">@t.BoardCount</span>
                            </div>
                        </div>

                        <div class="flex items-center justify-between">
                            <div class="px-2.5 py-1 rounded-full bg-secondary-container text-on-secondary-container text-[10px] font-bold uppercase tracking-wider">
                                @t.MemberCount @(t.MemberCount == 1 ? "Member" : "Members")
                            </div>
                            <button class="text-xs text-primary font-bold uppercase tracking-wider">Manage</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="px-10 py-10">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
            <div class="lg:col-span-3 glass-panel rounded-xl p-8 flex items-center justify-between border border-white/5">
                <div>
                    <p class="text-primary font-bold uppercase tracking-[0.2em] text-[10px] mb-2">Organization Overview</p>
                    <h4 class="text-2xl font-headline font-bold text-on-surface mb-4">
                        @_teams.Count active @(_teams.Count == 1 ? "team" : "teams") across your organization.
                    </h4>
                    <div class="flex gap-8">
                        <div class="space-y-1">
                            <span class="text-outline text-xs block">Total Teams</span>
                            <span class="text-2xl font-headline font-bold text-on-surface">@_teams.Count</span>
                        </div>
                        <div class="space-y-1">
                            <span class="text-outline text-xs block">Total Members</span>
                            <span class="text-2xl font-headline font-bold text-on-surface">@_teams.Sum(t => t.MemberCount)</span>
                        </div>
                        <div class="space-y-1">
                            <span class="text-outline text-xs block">Total Team Boards</span>
                            <span class="text-2xl font-headline font-bold text-on-surface">@_teams.Sum(t => t.BoardCount)</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-surface-container-highest rounded-xl p-6 border border-white/5 flex flex-col justify-between">
                <span class="material-symbols-outlined text-tertiary text-3xl">account_tree</span>
                <div>
                    <h5 class="text-on-surface font-headline font-bold">Team Ownership</h5>
                    <p class="text-xs text-on-surface-variant mb-4">Create boards in team context to enforce access and ownership boundaries.</p>
                    <button class="w-full py-2 bg-surface rounded-lg text-xs font-bold border border-outline-variant/30"
                            @onclick="() => _showCreate = true">
                        Create Team
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@if (_showCreate)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4"
         @onclick="CloseCreateModal">
        <div class="glass-panel w-full max-w-xl rounded-xl shadow-[0_24px_40px_-4px_rgba(0,0,0,0.4)] overflow-hidden"
             @onclick:stopPropagation>
            <div class="px-8 pt-8 pb-6 flex justify-between items-start">
                <div>
                    <h2 class="text-2xl font-bold font-headline text-on-surface tracking-tight">Create Team</h2>
                    <p class="text-on-surface-variant text-sm mt-1">Establish a collaborative space with shared board ownership.</p>
                </div>
                <button @onclick="CloseCreateModal" class="text-on-surface-variant hover:text-on-surface transition-colors p-1">
                    <span class="material-symbols-outlined text-2xl">close</span>
                </button>
            </div>

            <div class="px-8 pb-8 space-y-8">
                <div class="space-y-2">
                    <label class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant">Team Name</label>
                    <input @bind="_newName" @bind:event="oninput"
                           placeholder="e.g. Core Architecture"
                           class="w-full bg-transparent border-0 border-b border-outline-variant focus:border-primary text-on-surface font-medium px-0 py-3 placeholder:text-outline text-lg outline-none" />
                    @if (_createError is not null)
                    {
                        <p class="text-xs text-error">@_createError</p>
                    }
                </div>

                <div class="space-y-2">
                    <label class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant">Team Description</label>
                    <textarea @bind="_newDescription"
                              placeholder="Define this team's scope, responsibilities, and boundaries..."
                              rows="3"
                              class="w-full bg-transparent border-0 border-b border-outline-variant focus:border-primary text-on-surface px-0 py-3 placeholder:text-outline resize-none outline-none"></textarea>
                </div>

                <div class="space-y-3">
                    <label class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant">Invite Members</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-0 top-1/2 -translate-y-1/2 text-outline">person_add</span>
                        <input value="@_createMemberSearch" @oninput="OnCreateMemberSearchChanged"
                               placeholder="Search by name or email"
                               class="w-full bg-transparent border-0 border-b border-outline-variant focus:border-primary text-on-surface pl-8 py-3 placeholder:text-outline outline-none" />
                    </div>
                    <p class="text-[11px] text-on-surface-variant">
                        Select from suggestions, or paste comma-separated emails to add multiple people.
                    </p>

                    @if (_createSearchResults.Count > 0)
                    {
                        <div class="bg-surface-container-high rounded-xl border border-outline-variant/30 overflow-hidden">
                            @foreach (var result in _createSearchResults)
                            {
                                var r = result;
                                <button @onclick="() => AddMemberToCreateInviteList(r)"
                                        class="w-full flex items-center gap-3 px-4 py-2.5 hover:bg-surface-bright transition-colors text-left">
                                    <div class="w-7 h-7 rounded-full bg-primary-container flex items-center justify-center text-xs font-bold text-on-primary-container">
                                        @GetInitial(r.DisplayName)
                                    </div>
                                    <div>
                                        <p class="text-sm font-medium text-on-surface">@r.DisplayName</p>
                                        <p class="text-xs text-on-surface-variant">@r.Email</p>
                                    </div>
                                </button>
                            }
                        </div>
                    }

                    @if (_invitedMembers.Count > 0)
                    {
                        <div class="flex flex-wrap gap-2 pt-1">
                            @foreach (var member in _invitedMembers)
                            {
                                var m = member;
                                <div class="flex items-center gap-2 bg-surface-container-high px-3 py-1.5 rounded-full text-sm border border-outline-variant/15">
                                    <div class="w-5 h-5 rounded-full bg-primary-container flex items-center justify-center text-[10px] font-bold text-on-primary-container">
                                        @GetInitial(m.DisplayName)
                                    </div>
                                    <span>@m.DisplayName</span>
                                    <button @onclick="() => _invitedMembers.Remove(m)"
                                            class="material-symbols-outlined text-sm text-outline hover:text-error leading-none">
                                        close
                                    </button>
                                </div>
                            }
                        </div>
                    }

                    @if (_pendingInviteEmails.Count > 0)
                    {
                        <div class="space-y-2">
                            <p class="text-[11px] text-on-surface-variant">Pending email invites (account not found yet):</p>
                            <p class="text-[11px] text-on-surface-variant">These people are not added automatically until they create an account and join through a board invite link.</p>
                            <div class="flex flex-wrap gap-2">
                                @foreach (var email in _pendingInviteEmails)
                                {
                                    var pendingEmail = email;
                                    <div class="flex items-center gap-2 bg-tertiary/10 text-tertiary px-3 py-1.5 rounded-full text-xs border border-tertiary/20">
                                        <span>@pendingEmail</span>
                                        <button @onclick="() => _pendingInviteEmails.Remove(pendingEmail)"
                                                class="material-symbols-outlined text-sm leading-none">
                                            close
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="flex items-center justify-end gap-6 pt-4">
                    <button @onclick="CloseCreateModal"
                            class="text-on-surface-variant font-headline font-bold hover:text-on-surface transition-all tracking-wide text-sm">
                        Cancel
                    </button>
                    <button @onclick="CreateTeam" disabled="@_creating"
                            class="bg-gradient-to-br from-primary to-primary-dim text-on-primary px-8 py-3 rounded-xl font-headline font-bold shadow-lg shadow-primary/20 disabled:opacity-50">
                        @(_creating ? "Creating..." : "Create Team")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showTeamDetails && _selectedTeam is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4"
         @onclick="CloseTeamDetailsModal">
        <div class="glass-panel w-full max-w-4xl rounded-xl shadow-[0_24px_40px_-4px_rgba(0,0,0,0.4)] overflow-hidden"
             @onclick:stopPropagation>
            <div class="px-8 pt-8 pb-6 flex justify-between items-start border-b border-white/5">
                <div>
                    <h2 class="text-2xl font-bold font-headline text-on-surface tracking-tight">@_selectedTeam.Name</h2>
                    <p class="text-on-surface-variant text-sm mt-1">@(_selectedTeam.Description ?? "No description provided.")</p>
                </div>
                <button @onclick="CloseTeamDetailsModal" class="text-on-surface-variant hover:text-on-surface transition-colors p-1">
                    <span class="material-symbols-outlined text-2xl">close</span>
                </button>
            </div>

            <div class="px-8 py-6 grid grid-cols-1 lg:grid-cols-2 gap-8 max-h-[70vh] overflow-y-auto">
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <h3 class="font-headline font-bold text-on-surface">Team Boards</h3>
                        <span class="text-[10px] font-bold uppercase tracking-wider text-primary bg-primary/10 px-2 py-1 rounded-full">@_teamBoards.Count boards</span>
                    </div>

                    <div class="flex gap-2">
                        <input @bind="_newTeamBoardName" @bind:event="oninput"
                               placeholder="New board name"
                               class="flex-1 bg-transparent border-0 border-b border-outline-variant focus:border-primary text-on-surface px-0 py-2 placeholder:text-outline outline-none" />
                        <button @onclick="CreateBoardForSelectedTeam"
                                class="btn-gradient text-white px-4 py-2 rounded-lg text-sm font-bold">
                            Create
                        </button>
                    </div>
                    @if (_teamActionError is not null)
                    {
                        <p class="text-xs text-error">@_teamActionError</p>
                    }

                    @if (_teamBoards.Count == 0)
                    {
                        <p class="text-sm text-on-surface-variant">No boards for this team yet.</p>
                    }
                    else
                    {
                        <div class="space-y-2">
                            @foreach (var board in _teamBoards)
                            {
                                var b = board;
                                <button class="w-full p-3 rounded-lg bg-surface-container-high border border-outline-variant/20 text-left hover:bg-surface-bright transition-colors"
                                        @onclick='() => Nav.NavigateTo($"/board/{b.Id}")'>
                                    <p class="font-semibold text-on-surface">@b.Name</p>
                                    <p class="text-xs text-on-surface-variant">@b.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</p>
                                </button>
                            }
                        </div>
                    }
                </div>

                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <h3 class="font-headline font-bold text-on-surface">Members</h3>
                        <span class="text-[10px] font-bold uppercase tracking-wider text-primary bg-primary/10 px-2 py-1 rounded-full">@_selectedTeam.MemberCount members</span>
                    </div>

                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-0 top-1/2 -translate-y-1/2 text-outline">person_add</span>
                        <input value="@_teamMemberSearch" @oninput="OnTeamMemberSearchChanged"
                               placeholder="Add member by name/email"
                               class="w-full bg-transparent border-0 border-b border-outline-variant focus:border-primary text-on-surface pl-8 py-2 placeholder:text-outline outline-none" />
                    </div>

                    @if (_teamSearchResults.Count > 0)
                    {
                        <div class="bg-surface-container-high rounded-xl border border-outline-variant/30 overflow-hidden">
                            @foreach (var result in _teamSearchResults)
                            {
                                var r = result;
                                <button @onclick="() => AddMemberToSelectedTeam(r)"
                                        class="w-full flex items-center gap-3 px-4 py-2.5 hover:bg-surface-bright transition-colors text-left">
                                    <div class="w-7 h-7 rounded-full bg-primary-container flex items-center justify-center text-xs font-bold text-on-primary-container">
                                        @GetInitial(r.DisplayName)
                                    </div>
                                    <div>
                                        <p class="text-sm font-medium text-on-surface">@r.DisplayName</p>
                                        <p class="text-xs text-on-surface-variant">@r.Email</p>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                    else if (_teamSearchResults.Count == 0 && LooksLikeEmail(_teamMemberSearch))
                    {
                        @* No matching account found — offer email invite inline *@
                        <div class="flex items-center justify-between px-4 py-2.5 rounded-xl bg-surface-container-high border border-outline-variant/30">
                            <div class="flex items-center gap-2 min-w-0">
                                <span class="material-symbols-outlined text-outline text-base">mail</span>
                                <p class="text-sm text-on-surface-variant truncate">
                                    No account found — send invite to <span class="font-medium text-on-surface">@_teamMemberSearch</span>
                                </p>
                            </div>
                            <button @onclick="SendInvite" disabled="@_inviting"
                                    class="ml-3 bg-primary text-on-primary px-3 py-1.5 rounded-lg text-xs font-bold
                                           hover:opacity-90 active:scale-95 transition-all disabled:opacity-50 whitespace-nowrap">
                                @(_inviting ? "Sending…" : "Send Invite")
                            </button>
                        </div>
                    }

                    @if (_inviteMessage is not null)
                    {
                        <p class="text-xs @(_inviteSuccess ? "text-green-400" : "text-error")">@_inviteMessage</p>
                    }

                    <div class="space-y-2">
                        @foreach (var member in _selectedTeam.Members)
                        {
                            var m = member;
                            <div class="flex items-center justify-between p-3 rounded-lg bg-surface-container-high border border-outline-variant/20">
                                <div class="flex items-center gap-3 min-w-0">
                                    <div class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center text-xs font-bold text-on-primary-container">
                                        @GetInitial(string.IsNullOrEmpty(m.Email) ? m.DisplayName : m.Email)
                                    </div>
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-on-surface truncate">@(string.IsNullOrEmpty(m.Email) ? m.DisplayName : m.Email)</p>
                                        <p class="text-[10px] text-on-surface-variant uppercase tracking-wider">@m.Role</p>
                                    </div>
                                </div>
                                @if (m.Role != "Owner")
                                {
                                    <button class="material-symbols-outlined text-on-surface-variant hover:text-error transition-colors"
                                            @onclick="() => RemoveMemberFromSelectedTeam(m.UserId)">
                                        person_remove
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    bool _loading = true;
    bool _showCreate;
    bool _showTeamDetails;
    bool _creating;
    bool _inviting;
    bool _inviteSuccess;

    string _newName = "";
    string _newDescription = "";
    string? _createError;
    string? _teamActionError;

    string _createMemberSearch = "";
    string _teamMemberSearch = "";
    string _newTeamBoardName = "";

    List<TeamDto> _teams = [];
    TeamDto? _selectedTeam;
    List<TeamBoardDto> _teamBoards = [];
    List<UserSearchDto> _createSearchResults = [];
    List<UserSearchDto> _teamSearchResults = [];
    List<UserSearchDto> _invitedMembers = [];
    List<string> _pendingInviteEmails = [];

    string? _inviteMessage;

    CancellationTokenSource? _createSearchCts;
    CancellationTokenSource? _teamSearchCts;

    protected override async Task OnInitializedAsync()
    {
        await LoadTeams();
    }

    async Task LoadTeams()
    {
        _loading = true;
        try
        {
            _teams = await Http.GetFromJsonAsync<List<TeamDto>>("/api/teams") ?? [];
        }
        catch
        {
            _teams = [];
        }
        _loading = false;
    }

    async Task OpenTeam(TeamDto team)
    {
        _teamActionError = null;
        _showTeamDetails = true;
        _selectedTeam = await Http.GetFromJsonAsync<TeamDto>($"/api/teams/{team.Id}") ?? team;
        await LoadSelectedTeamBoards();
    }

    async Task LoadSelectedTeamBoards()
    {
        if (_selectedTeam is null) return;
        try
        {
            _teamBoards = await Http.GetFromJsonAsync<List<TeamBoardDto>>($"/api/teams/{_selectedTeam.Id}/boards") ?? [];
        }
        catch
        {
            _teamBoards = [];
        }
    }

    async Task OnCreateMemberSearchChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";
        if (raw.Contains(','))
        {
            await ProcessCreateInviteInput(raw);
            return;
        }

        _createMemberSearch = raw;
        _createSearchCts?.Cancel();
        _createSearchCts = new CancellationTokenSource();
        var token = _createSearchCts.Token;
        _createSearchResults = await SearchUsersAsync(_createMemberSearch, token);
    }

    async Task ProcessCreateInviteInput(string raw)
    {
        var endsWithComma = raw.EndsWith(",", StringComparison.Ordinal);
        var parts = raw.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 0)
        {
            _createMemberSearch = "";
            _createSearchResults = [];
            return;
        }

        var tokensToResolve = endsWithComma ? parts : parts[..^1];
        foreach (var token in tokensToResolve.Distinct(StringComparer.OrdinalIgnoreCase))
            await TryResolveAndInviteByToken(token);

        _createMemberSearch = endsWithComma ? "" : parts[^1];
        _createSearchCts?.Cancel();
        _createSearchCts = new CancellationTokenSource();
        _createSearchResults = await SearchUsersAsync(_createMemberSearch, _createSearchCts.Token);
    }

    async Task TryResolveAndInviteByToken(string token)
    {
        if (string.IsNullOrWhiteSpace(token) || token.Length < 2) return;

        try
        {
            var results = await Http.GetFromJsonAsync<List<UserSearchDto>>(
                $"/api/users/search?q={Uri.EscapeDataString(token)}");
            if (results is null || results.Count == 0)
            {
                AddPendingEmail(token);
                return;
            }

            var exact = results.FirstOrDefault(r =>
                string.Equals(r.Email, token, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(r.DisplayName, token, StringComparison.OrdinalIgnoreCase));

            AddMemberToCreateInviteList(exact ?? results[0]);
        }
        catch
        {
            // Ignore token parse failures; user can still pick from dropdown manually.
        }
    }

    async Task OnTeamMemberSearchChanged(ChangeEventArgs e)
    {
        _teamMemberSearch = e.Value?.ToString() ?? "";
        _teamSearchCts?.Cancel();
        _teamSearchCts = new CancellationTokenSource();
        var token = _teamSearchCts.Token;
        var members = _selectedTeam?.Members.Select(m => m.UserId).ToHashSet() ?? [];
        _teamSearchResults = (await SearchUsersAsync(_teamMemberSearch, token))
            .Where(u => !members.Contains(u.UserId))
            .ToList();
    }

    async Task<List<UserSearchDto>> SearchUsersAsync(string query, CancellationToken token)
    {
        if (query.Length < 2) return [];

        try
        {
            await Task.Delay(250, token);
            var results = await Http.GetFromJsonAsync<List<UserSearchDto>>(
                $"/api/users/search?q={Uri.EscapeDataString(query)}",
                token);
            return results ?? [];
        }
        catch (OperationCanceledException)
        {
            return [];
        }
        catch
        {
            return [];
        }
    }

    void AddMemberToCreateInviteList(UserSearchDto user)
    {
        _pendingInviteEmails.RemoveAll(e =>
            string.Equals(e, user.Email, StringComparison.OrdinalIgnoreCase));
        if (!_invitedMembers.Any(m => m.UserId == user.UserId))
            _invitedMembers.Add(user);
        _createMemberSearch = "";
        _createSearchResults = [];
    }

    void AddPendingEmail(string token)
    {
        if (!LooksLikeEmail(token)) return;
        if (_pendingInviteEmails.Any(e => string.Equals(e, token, StringComparison.OrdinalIgnoreCase)))
            return;
        _pendingInviteEmails.Add(token);
    }

    async Task AddMemberToSelectedTeam(UserSearchDto user)
    {
        if (_selectedTeam is null) return;

        _teamActionError = null;
        var resp = await Http.PostAsJsonAsync($"/api/teams/{_selectedTeam.Id}/members", new { user.UserId });
        if (!resp.IsSuccessStatusCode)
        {
            _teamActionError = $"Could not add member ({(int)resp.StatusCode}).";
            return;
        }

        var newMember = new TeamMemberDto(user.UserId, user.DisplayName, user.AvatarUrl, "Member", DateTime.UtcNow);
        var updatedMembers = _selectedTeam.Members.Append(newMember).ToList();
        _selectedTeam = _selectedTeam with
        {
            Members = updatedMembers,
            MemberCount = updatedMembers.Count
        };
        SyncTeamList(_selectedTeam);
        _teamMemberSearch = "";
        _teamSearchResults = [];
    }

    async Task RemoveMemberFromSelectedTeam(string userId)
    {
        if (_selectedTeam is null) return;

        _teamActionError = null;
        var resp = await Http.DeleteAsync($"/api/teams/{_selectedTeam.Id}/members/{Uri.EscapeDataString(userId)}");
        if (!resp.IsSuccessStatusCode)
        {
            _teamActionError = $"Could not remove member ({(int)resp.StatusCode}).";
            return;
        }

        var updatedMembers = _selectedTeam.Members.Where(m => m.UserId != userId).ToList();
        _selectedTeam = _selectedTeam with
        {
            Members = updatedMembers,
            MemberCount = updatedMembers.Count
        };
        SyncTeamList(_selectedTeam);
    }

    async Task CreateBoardForSelectedTeam()
    {
        if (_selectedTeam is null) return;
        if (string.IsNullOrWhiteSpace(_newTeamBoardName))
        {
            _teamActionError = "Board name is required.";
            return;
        }

        _teamActionError = null;
        var resp = await Http.PostAsJsonAsync(
            $"/api/teams/{_selectedTeam.Id}/boards",
            new TeamCreateBoardRequest(_newTeamBoardName.Trim(), null));

        if (!resp.IsSuccessStatusCode)
        {
            _teamActionError = $"Failed to create board ({(int)resp.StatusCode}).";
            return;
        }

        var board = await resp.Content.ReadFromJsonAsync<TeamBoardDto>();
        if (board is not null)
        {
            _teamBoards.Insert(0, board);
            _selectedTeam = _selectedTeam with { BoardCount = _selectedTeam.BoardCount + 1 };
            SyncTeamList(_selectedTeam);
            _newTeamBoardName = "";
        }
    }

    async Task CreateTeam()
    {
        _createError = null;

        if (string.IsNullOrWhiteSpace(_newName))
        {
            _createError = "Team name is required.";
            return;
        }

        _creating = true;
        try
        {
            var request = new CreateTeamRequest(
                _newName.Trim(),
                string.IsNullOrWhiteSpace(_newDescription) ? null : _newDescription.Trim(),
                null,
                _invitedMembers.Select(m => m.UserId).ToList());

            var response = await Http.PostAsJsonAsync("/api/teams", request);
            if (response.IsSuccessStatusCode)
            {
                CloseCreateModal();
                await LoadTeams();
            }
            else
            {
                _createError = "Failed to create team. Please try again.";
            }
        }
        catch
        {
            _createError = "An error occurred. Please try again.";
        }
        finally
        {
            _creating = false;
        }
    }

    async Task DeleteTeam(TeamDto team)
    {
        var response = await Http.DeleteAsync($"/api/teams/{team.Id}");
        if (!response.IsSuccessStatusCode) return;

        _teams.RemoveAll(t => t.Id == team.Id);
        if (_selectedTeam?.Id == team.Id)
            CloseTeamDetailsModal();
    }

    void CloseCreateModal()
    {
        _showCreate = false;
        _newName = "";
        _newDescription = "";
        _createMemberSearch = "";
        _createError = null;
        _invitedMembers = [];
        _pendingInviteEmails = [];
        _createSearchResults = [];
    }

    async Task SendInvite()
    {
        _inviteMessage = null;
        var email = _teamMemberSearch.Trim();

        _inviting = true;
        try
        {
            var resp = await Http.PostAsJsonAsync(
                $"/api/teams/{_selectedTeam!.Id}/invite-email",
                new { Email = email });

            if (resp.IsSuccessStatusCode)
            {
                _inviteMessage = $"Invite sent to {email}!";
                _inviteSuccess = true;
                _teamMemberSearch = "";
                _teamSearchResults = [];
            }
            else
            {
                _inviteMessage = "Failed to send invite. Please try again.";
                _inviteSuccess = false;
            }
        }
        catch
        {
            _inviteMessage = "An error occurred. Please try again.";
            _inviteSuccess = false;
        }
        finally
        {
            _inviting = false;
        }
    }

    void CloseTeamDetailsModal()
    {
        _showTeamDetails = false;
        _selectedTeam = null;
        _teamBoards = [];
        _teamMemberSearch = "";
        _teamSearchResults = [];
        _newTeamBoardName = "";
        _teamActionError = null;
        _inviteMessage = null;
    }

    void SyncTeamList(TeamDto updated)
    {
        var idx = _teams.FindIndex(t => t.Id == updated.Id);
        if (idx >= 0) _teams[idx] = updated;
    }

    static string GetInitial(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        return name[..1].ToUpperInvariant();
    }

    static bool LooksLikeEmail(string value)
    {
        var at = value.IndexOf('@');
        var dot = value.LastIndexOf('.');
        return at > 0 && dot > at + 1 && dot < value.Length - 1;
    }
}
