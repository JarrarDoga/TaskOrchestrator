@page "/"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState
@using TaskOrchestrator.Client.Components

<PageTitle>Orchestrator — Active Boards</PageTitle>

<div class="flex flex-col h-full overflow-y-auto">
    @* Header *@
    <div class="flex items-end justify-between px-10 pt-10 pb-6">
        <div>
            <h1 class="text-4xl font-headline font-extrabold text-on-surface tracking-tight mb-1">Active Boards</h1>
            <p class="text-on-surface-variant font-body">Manage your workflows and sprint progress.</p>
        </div>
        <button @onclick="() => _showCreate = true"
                class="btn-gradient text-white px-6 py-3 rounded-xl font-headline font-bold flex items-center gap-2 hover:opacity-90 active:scale-95 transition-all shadow-lg shadow-primary/20">
            <span class="material-symbols-outlined text-lg">add_circle</span>
            + New Board
        </button>
    </div>

    @* Board grid *@
    <div class="px-10">
        @if (_loading)
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                @for (int i = 0; i < 3; i++) {
                    <div class="h-48 rounded-xl bg-surface-container-high animate-pulse"></div>
                }
            </div>
        }
        else if (_boards.Count == 0)
        {
            <div class="flex flex-col items-center justify-center py-24 text-center">
                <span class="material-symbols-outlined text-5xl text-outline mb-4">dashboard</span>
                <p class="text-on-surface-variant text-sm">No boards yet. Create one to get started.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                @foreach (var b in _boards)
                {
                    <div class="group relative bg-surface-container-high rounded-xl p-6 transition-all duration-200
                                hover:bg-surface-bright border border-white/5 hover:border-primary/30 shadow-lg cursor-pointer"
                         @onclick="() => OpenBoard(b.Id)">
                        <div class="flex justify-between items-start mb-6">
                            <div class="h-12 w-12 rounded-lg bg-surface-container-highest flex items-center justify-center
                                        text-primary font-headline font-bold text-xl">
                                @b.Name[..1].ToUpper()
                            </div>
                            <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">north_east</span>
                        </div>
                        <h3 class="text-base font-headline font-semibold text-on-surface mb-6 line-clamp-2">@b.Name</h3>
                        <div class="flex items-center justify-between">
                            <button class="text-sm font-medium text-on-surface-variant hover:text-primary flex items-center gap-1.5 transition-colors"
                                    @onclick="() => OpenManage(b.Id)" @onclick:stopPropagation>
                                <span class="material-symbols-outlined text-base">settings</span>
                                Manage
                            </button>
                            <span class="text-[10px] font-bold uppercase tracking-wider text-on-surface-variant/40">Private</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* Create board form *@
    @if (_showCreate)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/60" @onclick="() => _showCreate = false">
            <div class="w-96 rounded-2xl border border-outline-variant bg-surface-container p-6 shadow-2xl" @onclick:stopPropagation>
                <h3 class="font-headline font-bold text-on-surface text-lg mb-4">New Board</h3>
                <input @bind="_newName" @bind:event="oninput" @onkeydown="OnKeyDown"
                       placeholder="Board name"
                       class="w-full rounded-lg border border-outline-variant bg-surface-container-high px-4 py-2.5
                              text-sm text-on-surface placeholder-on-surface-variant/50 focus:border-primary focus:outline-none mb-3" />
                @if (_createError is not null)
                {
                    <p class="mb-3 text-xs text-error">@_createError</p>
                }
                <div class="flex gap-3">
                    <button @onclick="() => _showCreate = false"
                            class="flex-1 rounded-lg border border-outline-variant px-4 py-2.5 text-sm text-on-surface-variant hover:text-on-surface transition-colors">
                        Cancel
                    </button>
                    <button @onclick="CreateBoard" disabled="@_creating"
                            class="flex-1 btn-gradient rounded-lg px-4 py-2.5 text-sm font-headline font-bold text-white hover:opacity-90 transition-all disabled:opacity-50">
                        Create
                    </button>
                </div>
            </div>
        </div>
    }

    @* Invite code section *@
    <div class="px-10 py-10">
        <div class="glass-panel rounded-2xl p-8 max-w-2xl border border-white/5 relative overflow-hidden">
            <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/10 rounded-full blur-[80px] pointer-events-none"></div>
            <div class="relative z-10">
                <h4 class="text-2xl font-headline font-bold text-on-surface mb-1">Have an invite code?</h4>
                <p class="text-on-surface-variant text-sm mb-6">Enter a project key to join an existing workspace board.</p>
                <div class="flex gap-3">
                    <input @bind="_joinCode" @bind:event="oninput"
                           placeholder="Enter workspace code..."
                           class="flex-1 bg-transparent border-0 border-b border-outline-variant focus:border-primary focus:outline-none
                                  text-on-surface py-2 text-sm placeholder-on-surface-variant/50 transition-colors" />
                    <button @onclick="JoinByCode"
                            class="bg-surface-container-highest hover:bg-surface-bright text-on-surface px-6 py-2.5 rounded-xl
                                   font-headline font-bold text-sm transition-all border border-white/5 active:scale-95">
                        Join
                    </button>
                </div>
                @if (_joinError is not null)
                {
                    <p class="mt-2 text-xs text-error">@_joinError</p>
                }
            </div>
        </div>
    </div>

    @* Footer *@
    <footer class="text-center pb-6 opacity-20 select-none pointer-events-none">
        <p class="text-xs font-medium tracking-[0.2em] uppercase">Built for high-performance orchestration</p>
    </footer>
</div>

@* Board manage panel *@
<BoardManagePanel BoardId="_manageBoardId"
                  CurrentUserId="_manageCurrentUserId"
                  OnClosed="() => _manageBoardId = null" />

@code {
    List<BoardDto> _boards = [];
    bool _loading = true;

    bool _showCreate;
    string _newName = "";
    bool _creating;
    string? _createError;

    string _joinCode = "";
    string? _joinError;

    int? _manageBoardId;
    string? _manageCurrentUserId;

    protected override async Task OnInitializedAsync()
    {
        await Http.PostAsync("/api/me/sync", null);
        var authState = await AuthState.GetAuthenticationStateAsync();
        _manageCurrentUserId = authState.User.FindFirst("sub")?.Value;
        var result = await Http.GetFromJsonAsync<List<BoardDto>>("/api/me/boards");
        _boards = result ?? [];
        _loading = false;
    }

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CreateBoard();
        if (e.Key == "Escape") _showCreate = false;
    }

    async Task CreateBoard()
    {
        if (string.IsNullOrWhiteSpace(_newName)) { _createError = "Name is required."; return; }
        _creating = true;
        _createError = null;
        var resp = await Http.PostAsJsonAsync("/api/boards", new CreateBoardRequest(_newName.Trim(), null));
        if (resp.IsSuccessStatusCode)
        {
            var board = await resp.Content.ReadFromJsonAsync<BoardDto>();
            if (board is not null) Nav.NavigateTo($"/board/{board.Id}");
        }
        else
        {
            _createError = $"Failed to create board ({(int)resp.StatusCode}).";
            _creating = false;
        }
    }

    async Task JoinByCode()
    {
        _joinError = null;
        var code = _joinCode.Trim().ToUpperInvariant();
        if (string.IsNullOrWhiteSpace(code)) return;
        var resp = await Http.PostAsync($"/api/join/{code}", null);
        if (resp.IsSuccessStatusCode)
        {
            var data = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
            if (data.TryGetProperty("boardId", out var idEl))
                Nav.NavigateTo($"/board/{idEl.GetInt32()}");
        }
        else if (resp.StatusCode == System.Net.HttpStatusCode.NotFound)
            _joinError = "Invite code is invalid, expired, or exhausted.";
        else
            _joinError = $"Error {(int)resp.StatusCode}.";
    }

    void OpenBoard(int boardId) => Nav.NavigateTo($"/board/{boardId}");
    void OpenManage(int boardId) => _manageBoardId = boardId;
}
