@page "/join/{Code}"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Joining board… — Task Orchestrator</PageTitle>

<div class="flex flex-1 flex-col items-center justify-center gap-4 p-8 text-sm text-zinc-400">
    @if (_error is null)
    {
        <p>Joining board…</p>
    }
    else
    {
        <p class="text-red-400">@_error</p>
        <a href="/" class="text-zinc-500 hover:text-zinc-300 underline text-xs">Back to home</a>
    }
</div>

@code {
    [Parameter] public string Code { get; set; } = default!;
    string? _error;

    protected override async Task OnInitializedAsync()
    {
        var resp = await Http.PostAsync($"/api/join/{Code}", null);
        if (resp.IsSuccessStatusCode)
        {
            var data = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
            if (data.TryGetProperty("boardId", out var idEl))
                Nav.NavigateTo($"/board/{idEl.GetInt32()}", replace: true);
        }
        else if (resp.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _error = "This invite link is invalid, expired, or has been fully used.";
        }
        else
        {
            _error = $"Something went wrong (HTTP {(int)resp.StatusCode}).";
        }
    }
}
