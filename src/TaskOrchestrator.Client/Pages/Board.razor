@page "/board/{BoardId:int}"
@page "/board"
@attribute [Authorize]
@implements IAsyncDisposable
@inject HttpClient HttpClient
@inject IConfiguration Configuration
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState
@inject BoardStateService _stateService
@inject SignalRService _signalRService

@using System.Net.Http.Json
@using TaskOrchestrator.Client.Components
@using TaskOrchestrator.Client.Services
@using TaskOrchestrator.Shared.Contracts

<PageTitle>Board — Task Orchestrator</PageTitle>

@* Top nav bar *@
<header class="flex items-center justify-between px-6 h-14 border-b border-white/5 bg-transparent flex-shrink-0">
    <nav class="flex items-center gap-2 text-sm font-medium">
        <a href="/" class="text-on-surface-variant hover:text-on-surface transition-colors">Workspace</a>
        <span class="material-symbols-outlined text-xs text-outline">chevron_right</span>
        <span class="text-on-surface-variant hover:text-on-surface transition-colors cursor-default">Boards</span>
        <span class="material-symbols-outlined text-xs text-outline">chevron_right</span>
        <span class="text-primary font-semibold">@(_state.Board?.Name ?? "Loading...")</span>
    </nav>
    <div class="flex items-center gap-4">
        <div class="hidden lg:flex items-center bg-surface-container-high rounded-full px-4 py-1.5 border border-white/5 gap-2">
            <span class="material-symbols-outlined text-on-surface-variant text-base">search</span>
            <input class="bg-transparent border-none focus:ring-0 text-xs w-40 text-on-surface placeholder-on-surface-variant/50 focus:outline-none"
                   placeholder="Search cards..." />
        </div>
        <PresenceAvatars Users="_state.ActiveUsers" />
        <ConnectionStatus State="_signalR.State" />
        <button class="btn-gradient px-4 py-1.5 rounded-lg text-xs font-headline font-bold text-white hover:opacity-90 transition-all"
                @onclick="() => _showAddColumn = true">
            New Card
        </button>
    </div>
</header>

@* Board title bar *@
<div class="px-8 pt-6 pb-4 flex-shrink-0">
    <h2 class="text-2xl font-headline font-extrabold text-on-surface tracking-tight">@(_state.Board?.Name ?? "")</h2>
    @if (_state.LoadError is not null)
    {
        <p class="mt-1 text-xs text-error">⚠ @_state.LoadError</p>
    }
</div>

@* Board canvas *@
<div class="flex flex-1 gap-5 overflow-x-auto overflow-y-hidden px-8 pb-6">
    @if (_state.IsLoading)
    {
        @for (int i = 0; i < 4; i++)
        {
            <div class="w-72 flex-shrink-0 rounded-lg border border-zinc-800 bg-zinc-900/60 animate-pulse">
                <div class="h-10 border-b border-zinc-800"></div>
                <div class="p-2 flex flex-col gap-2">
                    <div class="h-14 rounded bg-zinc-800"></div>
                    <div class="h-14 rounded bg-zinc-800"></div>
                    <div class="h-10 rounded bg-zinc-800 opacity-50"></div>
                </div>
            </div>
        }
    }
    else if (_state.Board is not null)
    {
        @foreach (var col in _state.Board.Columns.OrderBy(c => c.Position))
        {
            <KanbanColumn Column="col"
                          DraggingCardId="_dragging?.Id"
                          OnDragStarted="OnCardDragStart"
                          OnDragEnded="OnCardDragEnd"
                          OnDropped="@(args => OnDrop(col.Id, args.Item2))"
                          CardClicked="OnCardClicked"
                          AddCardRequested="OnAddCardRequested"
                          DeleteRequested="DeleteColumn"
                          UpdateRequested="UpdateColumn"
                          MoveRequested="MoveColumn" />
        }

        @* Add column inline form *@
        @if (_showAddColumn)
        {
            <div class="w-72 flex-shrink-0 rounded-lg border border-zinc-700 bg-zinc-900 p-3 self-start">
                <p class="text-[10px] uppercase tracking-widest text-zinc-600 mb-2">New column</p>
                <input class="w-full rounded border border-zinc-700 bg-zinc-800 px-3 py-1.5 text-sm
                              text-zinc-100 focus:border-blue-500 focus:outline-none mb-2"
                       placeholder="Column title"
                       @bind="_newColumnTitle" @bind:event="oninput"
                       @onkeydown="OnAddColumnKeyDown"
                       @ref="_addColumnInput" />
                <div class="flex items-center gap-2 mb-2">
                    <label class="text-xs text-zinc-600">Color</label>
                    <input type="color" @bind="_newColumnColor"
                           class="h-6 w-8 cursor-pointer rounded border border-zinc-700 bg-zinc-800 p-0.5" />
                </div>
                @if (_addColumnError is not null)
                {
                    <p class="mb-1 text-xs text-red-400">@_addColumnError</p>
                }
                <div class="flex gap-2 justify-end">
                    <button class="rounded border border-zinc-700 px-3 py-1 text-xs text-zinc-500
                                   hover:text-zinc-300 transition-colors"
                            @onclick="() => _showAddColumn = false">Cancel</button>
                    <button class="rounded border border-blue-700 bg-blue-900/40 px-3 py-1 text-xs text-blue-300
                                   hover:bg-blue-900/60 transition-colors"
                            @onclick="ConfirmAddColumn">Add</button>
                </div>
            </div>
        }
        else
        {
            <button class="w-64 flex-shrink-0 rounded-lg border border-dashed border-zinc-800 py-4
                           text-sm text-zinc-600 hover:border-zinc-700 hover:text-zinc-400 transition-colors self-start"
                    @onclick="ShowAddColumn">
                + Add column
            </button>
        }
    }

    @* Activity sidebar — right edge *@
    @if (_state.Board is not null && _showActivity)
    {
        <aside class="w-64 flex-shrink-0 rounded-lg border border-zinc-800 bg-zinc-900/60 flex flex-col">
            <div class="border-b border-zinc-800 px-3 py-2.5 flex items-center justify-between">
                <span class="text-xs font-semibold text-zinc-500 uppercase tracking-wider">Activity</span>
                <button class="text-zinc-600 hover:text-zinc-400 text-xs" @onclick='() => _showActivity = false'>✕</button>
            </div>
            <div class="p-3 flex-1 overflow-y-auto">
                <ActivityFeed Events="_state.RecentActivity" />
            </div>
        </aside>
    }
</div>

@* Add card quick form *@
@if (_addingToColumnId.HasValue)
{
    <div class="fixed inset-0 z-40 flex items-center justify-center bg-black/60" @onclick="CancelAdd">
        <div class="w-80 rounded-lg border border-zinc-700 bg-zinc-900 p-4 shadow-2xl" @onclick:stopPropagation>
            <h3 class="mb-3 text-sm font-semibold text-zinc-200">New Card</h3>
            <input class="w-full rounded border border-zinc-700 bg-zinc-800 px-3 py-1.5 text-sm text-zinc-100
                          focus:border-blue-500 focus:outline-none"
                   placeholder="Card title"
                   @bind="_newCardTitle"
                   @bind:event="oninput"
                   @onkeydown="OnNewCardKeyDown"
                   @ref="_newCardInput" />
            @if (_addError is not null)
            {
                <p class="mt-1 text-xs text-red-400">@_addError</p>
            }
            <div class="mt-3 flex gap-2 justify-end">
                <button class="rounded border border-zinc-700 px-3 py-1.5 text-xs text-zinc-500 hover:text-zinc-300 transition-colors"
                        @onclick="CancelAdd">Cancel</button>
                <button class="rounded border border-blue-700 bg-blue-900/40 px-3 py-1.5 text-xs text-blue-300
                               hover:bg-blue-900/60 transition-colors"
                        @onclick="ConfirmAdd">Add</button>
            </div>
        </div>
    </div>
}

@* Card detail drawer *@
<CardDetailDrawer Card="_selectedCard"
                  OnClosed="() => _selectedCard = null"
                  OnSaved="OnCardSaved"
                  OnDeleted="OnCardDeleted"
                  OnAttachmentUploaded="OnAttachmentUploaded" />

@* Conflict dialog *@
<ConflictDialog Conflict="_state.PendingConflict"
                Dismissed="OnConflictDismissed" />

@if (!_showActivity && _state.Board is not null)
{
    <button class="fixed bottom-6 right-6 glass-panel rounded-full border border-white/10 px-4 py-2
                   text-xs font-medium text-on-surface-variant hover:text-on-surface shadow-xl transition-colors"
            @onclick='() => _showActivity = true'>
        <span class="material-symbols-outlined text-sm align-middle mr-1">history</span>
        Activity (@_state.RecentActivity.Count)
    </button>
}

@code {
    [Parameter] public int BoardId { get; set; } = 1;

    // Convenience aliases used in markup
    BoardStateService _state => _stateService;
    SignalRService    _signalR => _signalRService;

    CardDto? _dragging;
    CardDto? _selectedCard;
    int? _addingToColumnId;
    string _newCardTitle = "";
    string? _addError;
    bool _showActivity = false;
    ElementReference _newCardInput;

    // Add column
    bool _showAddColumn;
    string _newColumnTitle = "";
    string _newColumnColor = "#3b82f6";
    string? _addColumnError;
    ElementReference _addColumnInput;

    protected override async Task OnInitializedAsync()
    {
        _state.OnChange   += StateHasChanged;
        _signalR.OnStateChanged += StateHasChanged;

        // Sync Auth0 profile into the Users table on first load.
        // ID token claims (email, name, picture) are available here in Blazor but may be absent
        // from the access token when a custom audience is used, so we send them in the body.
        var authState = await AuthState.GetAuthenticationStateAsync();
        var principal = authState.User;
        var userId      = principal.FindFirst("sub")?.Value ?? "";
        var displayName = principal.FindFirst("name")?.Value
                       ?? principal.FindFirst("nickname")?.Value
                       ?? "Unknown";
        var avatarUrl = principal.FindFirst("picture")?.Value;
        var email     = principal.FindFirst("email")?.Value
                     ?? principal.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;

        try
        {
            await HttpClient.PostAsJsonAsync("/api/me/sync", new SyncProfileRequest(displayName, email, avatarUrl));
        }
        catch { /* non-critical — page still loads */ }

        await _state.LoadBoardAsync(BoardId);

        try
        {
            await _signalR.ConnectAsync(
                BoardId, _state, userId, displayName,
                avatarUrl: avatarUrl,
                onMemberKicked: kickedId =>
                {
                    if (kickedId == userId)
                        Nav.NavigateTo("/", forceLoad: false);
                    return Task.CompletedTask;
                });
        }
        catch { /* Hub unavailable — board still works without live updates */ }
    }

    // Drag and drop
    void OnCardDragStart(CardDto card)
    {
        _dragging = card;
    }

    void OnCardDragEnd() => _dragging = null;

    async Task OnDrop(int targetColumnId, int targetPosition)
    {
        if (_dragging is null) return;
        var card = _dragging;
        _dragging = null;

        if (card.ColumnId == targetColumnId && card.Position == targetPosition) return;

        var (oldCol, oldPos) = _state.OptimisticMove(card.Id, targetColumnId, targetPosition);

        var req = new MoveCardRequest(targetColumnId, targetPosition, card.Version);
        var response = await HttpClient.PostAsJsonAsync($"/api/cards/{card.Id}/move", req);

        if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
        {
            _state.RevertMove(card.Id, oldCol, oldPos);
            var conflict = await response.Content.ReadFromJsonAsync<ConflictResponse<CardDto?>>();
            _state.SetConflict(new ConflictInfo(
                conflict?.Message ?? "Version conflict",
                conflict?.ServerSnapshot,
                card,
                ConflictKind.Move));
        }
        else if (!response.IsSuccessStatusCode)
        {
            _state.RevertMove(card.Id, oldCol, oldPos);
        }
        // On success: SignalR CardUpdated will sync the final state.
    }

    // Card detail
    void OnCardClicked(CardDto card) => _selectedCard = card;

    void OnCardSaved(CardDto updated)
    {
        _state.ApplyCardUpdated(updated);
        _selectedCard = updated;
    }

    async Task OnCardDeleted(int cardId)
    {
        try
        {
            var response = await HttpClient.DeleteAsync($"/api/cards/{cardId}");
            if (response.IsSuccessStatusCode)
            {
                _selectedCard = null;
                _state.ApplyCardDeleted(cardId);
                return;
            }
        }
        catch
        {
            // Network error (e.g. Railway cold-start drops the response).
            // Fall through: close the drawer and reload from server so the UI
            // reflects whatever state the server actually ended up in.
        }

        _selectedCard = null;
        await _state.LoadBoardAsync(BoardId);
    }

    void OnAttachmentUploaded(AttachmentDto att)
    {
        _state.ApplyAttachmentAdded(_selectedCard!.Id, att);
        if (_selectedCard.Attachments.Any(existing => existing.Id == att.Id))
            return;

        var url = att.Url.StartsWith("/", StringComparison.Ordinal)
            ? new Uri(HttpClient.BaseAddress!, att.Url).ToString()
            : att.Url;

        _selectedCard = _selectedCard with
        {
            Attachments = new List<AttachmentDto>(_selectedCard.Attachments)
            {
                att with { Url = url }
            }
        };
    }

    // Add card
    async Task OnAddCardRequested(int columnId)
    {
        _addingToColumnId = columnId;
        _newCardTitle = "";
        _addError = null;
        await Task.Yield();
        await _newCardInput.FocusAsync();
    }

    async Task OnNewCardKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ConfirmAdd();
        if (e.Key == "Escape") CancelAdd();
    }

    async Task ConfirmAdd()
    {
        if (string.IsNullOrWhiteSpace(_newCardTitle))
        {
            _addError = "Title is required.";
            return;
        }
        var req = new CreateCardRequest(BoardId, _addingToColumnId!.Value,
            _newCardTitle.Trim(), null, Shared.Enums.TaskPriority.Medium);

        var response = await HttpClient.PostAsJsonAsync("/api/cards", req);
        if (response.IsSuccessStatusCode)
        {
            var card = await response.Content.ReadFromJsonAsync<CardDto>();
            if (card is not null && _signalR.State != Microsoft.AspNetCore.SignalR.Client.HubConnectionState.Connected)
                _state.ApplyCardCreated(card);
            _addingToColumnId = null;
        }
        else
        {
            _addError = $"Error {(int)response.StatusCode}";
        }
    }

    void CancelAdd() => _addingToColumnId = null;

    // Add / delete column
    async Task ShowAddColumn()
    {
        _showAddColumn = true;
        _newColumnTitle = "";
        _addColumnError = null;
        await Task.Yield();
        await _addColumnInput.FocusAsync();
    }

    async Task OnAddColumnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ConfirmAddColumn();
        if (e.Key == "Escape") _showAddColumn = false;
    }

    async Task ConfirmAddColumn()
    {
        if (string.IsNullOrWhiteSpace(_newColumnTitle))
        {
            _addColumnError = "Title is required.";
            return;
        }
        var req = new CreateColumnRequest(BoardId, _newColumnTitle.Trim(), _newColumnColor);
        var response = await HttpClient.PostAsJsonAsync($"/api/boards/{BoardId}/columns", req);
        if (response.IsSuccessStatusCode)
        {
            var col = await response.Content.ReadFromJsonAsync<ColumnDto>();
            if (col is not null && _signalR.State != Microsoft.AspNetCore.SignalR.Client.HubConnectionState.Connected)
                _state.ApplyColumnCreated(col);
            _showAddColumn = false;
        }
        else
        {
            _addColumnError = $"Error {(int)response.StatusCode}";
        }
    }

    async Task DeleteColumn(int columnId)
    {
        var response = await HttpClient.DeleteAsync($"/api/boards/{BoardId}/columns/{columnId}");
        if (response.IsSuccessStatusCode &&
            _signalR.State != Microsoft.AspNetCore.SignalR.Client.HubConnectionState.Connected)
        {
            _state.ApplyColumnDeleted(columnId);
        }
    }

    async Task UpdateColumn((int ColumnId, string Title, string Color) args)
    {
        var col = _state.Board?.Columns.FirstOrDefault(c => c.Id == args.ColumnId);
        if (col is null) return;
        var req = new UpdateColumnRequest(args.Title, args.Color, col.Position);
        var response = await HttpClient.PatchAsJsonAsync($"/api/boards/{BoardId}/columns/{args.ColumnId}", req);
        if (response.IsSuccessStatusCode)
        {
            var updated = await response.Content.ReadFromJsonAsync<ColumnDto>();
            if (updated is not null && _signalR.State != Microsoft.AspNetCore.SignalR.Client.HubConnectionState.Connected)
                _state.ApplyColumnUpdated(updated);
        }
    }

    async Task MoveColumn((int ColumnId, int Delta) args)
    {
        if (_state.Board is null) return;
        var cols = _state.Board.Columns.OrderBy(c => c.Position).ToList();
        var idx = cols.FindIndex(c => c.Id == args.ColumnId);
        if (idx < 0) return;
        var newIdx = Math.Clamp(idx + args.Delta, 0, cols.Count - 1);
        if (newIdx == idx) return;

        // Optimistic swap — instant visual feedback
        _state.OptimisticSwapColumns(args.ColumnId, args.Delta);

        // Normalize ALL positions to 0,1,2,... after the swap to prevent DB drift
        // that causes "only pairs can swap" issues
        var reordered = _state.Board.Columns.OrderBy(c => c.Position).ToList();
        await Task.WhenAll(reordered.Select((col, i) =>
            HttpClient.PatchAsJsonAsync($"/api/boards/{BoardId}/columns/{col.Id}",
                new UpdateColumnRequest(col.Title, col.Color, i))));

        // Always reload to confirm canonical server positions
        await _state.LoadBoardAsync(BoardId);
    }

    async Task OnConflictDismissed(ConflictResolution resolution)
    {
        if (resolution == ConflictResolution.RetryWithServer
            && _state.PendingConflict?.ServerSnapshot is { } snap)
        {
            _state.ApplyCardUpdated(snap);
        }
        _state.ClearConflict();
        await Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        _stateService.OnChange       -= StateHasChanged;
        _signalRService.OnStateChanged -= StateHasChanged;
        await _signalRService.DisconnectAsync(BoardId);
        await _signalRService.DisposeAsync();
    }
}
