@page "/board"
@implements IAsyncDisposable
@inject HttpClient Http
@inject HubConnection HubConnection

<PageTitle>Board — Task Orchestrator</PageTitle>

<div class="p-6">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Board</h2>

    @if (_loading)
    {
        <p class="text-gray-500">Loading tasks...</p>
    }
    else if (_error is not null)
    {
        <p class="text-red-600">@_error</p>
    }
    else
    {
        <div class="flex gap-4 overflow-x-auto pb-4">
            @foreach (var status in Enum.GetValues<TaskItemStatus>())
            {
                <div class="flex w-64 flex-shrink-0 flex-col rounded-lg bg-white shadow">
                    <div class="border-b px-4 py-3">
                        <span class="font-semibold text-gray-700">@status</span>
                        <span class="ml-2 rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-500">
                            @_tasks.Count(t => t.Status == status)
                        </span>
                    </div>
                    <div class="flex flex-col gap-2 p-3 min-h-[8rem]">
                        @foreach (var task in _tasks.Where(t => t.Status == status).OrderBy(t => t.Position))
                        {
                            <div class="rounded border bg-gray-50 p-3 text-sm shadow-sm">
                                <p class="font-medium text-gray-800">@task.Title</p>
                                @if (!string.IsNullOrWhiteSpace(task.Description))
                                {
                                    <p class="mt-1 text-xs text-gray-500 line-clamp-2">@task.Description</p>
                                }
                                <span class="mt-2 inline-block rounded-full bg-blue-100 px-2 py-0.5 text-xs text-blue-700">
                                    @task.Priority
                                </span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    // Board ID will become a route parameter once multi-board support is wired up.
    private const int DefaultBoardId = 1;

    private List<TaskItemDto> _tasks = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadTasksAsync();
        await ConnectToHubAsync();
    }

    private async Task LoadTasksAsync()
    {
        try
        {
            _tasks = await Http.GetFromJsonAsync<List<TaskItemDto>>(
                $"/api/boards/{DefaultBoardId}/tasks") ?? [];
        }
        catch (Exception ex)
        {
            _error = $"Failed to load tasks: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ConnectToHubAsync()
    {
        HubConnection.On<TaskItemDto>("TaskCreated", task =>
        {
            _tasks.Add(task);
            InvokeAsync(StateHasChanged);
        });

        HubConnection.On<TaskItemDto>("TaskUpdated", updated =>
        {
            var index = _tasks.FindIndex(t => t.Id == updated.Id);
            if (index >= 0) _tasks[index] = updated;
            InvokeAsync(StateHasChanged);
        });

        HubConnection.On<object>("TaskDeleted", payload =>
        {
            // Payload contains { taskId, boardId } — full typed handling comes in the feature slice
            InvokeAsync(StateHasChanged);
        });

        await HubConnection.StartAsync();
        await HubConnection.SendAsync("JoinBoard", DefaultBoardId);
    }

    public async ValueTask DisposeAsync()
    {
        await HubConnection.SendAsync("LeaveBoard", DefaultBoardId);
        await HubConnection.DisposeAsync();
    }
}
