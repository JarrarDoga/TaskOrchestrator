@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<AuthorizeView>
    <Authorized>
        <div class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition-colors cursor-pointer">
            @if (_avatarUrl is not null)
            {
                <img src="@_avatarUrl" alt="avatar"
                     class="w-8 h-8 rounded-full object-cover border border-outline-variant flex-shrink-0" />
            }
            else
            {
                <div class="w-8 h-8 rounded-full bg-surface-container-high flex items-center justify-center text-xs font-headline font-bold text-primary flex-shrink-0">
                    @(_displayName?[..1].ToUpper() ?? "?")
                </div>
            }
            <div class="flex-1 min-w-0">
                <p class="text-xs font-semibold text-on-surface truncate">@_displayName</p>
                <p class="text-[10px] text-on-surface-variant truncate">@_email</p>
            </div>
            <button @onclick="Logout" title="Sign out"
                    class="text-on-surface-variant hover:text-on-surface transition-colors flex-shrink-0">
                <span class="material-symbols-outlined text-lg">logout</span>
            </button>
        </div>
    </Authorized>
    <NotAuthorized>
        <button @onclick="Login"
                class="flex items-center gap-3 px-4 py-2 text-sm text-on-surface-variant hover:text-on-surface transition-colors">
            <span class="material-symbols-outlined text-xl">login</span>
            <span>Sign in</span>
        </button>
    </NotAuthorized>
</AuthorizeView>

@code {
    string? _displayName;
    string? _avatarUrl;
    string? _email;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var user = state.User;
        _displayName = user.FindFirst("name")?.Value ?? user.FindFirst("nickname")?.Value ?? user.Identity?.Name;
        _avatarUrl   = user.FindFirst("picture")?.Value;
        _email       = user.FindFirst("email")?.Value;
    }

    void Login()  => Nav.NavigateToLogin("authentication/login");
    void Logout() => Nav.NavigateToLogout("authentication/logout");
}
