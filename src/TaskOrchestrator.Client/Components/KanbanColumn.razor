@using TaskOrchestrator.Shared.Contracts

<div class="flex w-72 flex-shrink-0 flex-col rounded-lg border @(IsDragOver ? "border-blue-500/60 bg-zinc-800/60" : "border-zinc-800 bg-zinc-900/60")
            transition-colors duration-100 max-h-full"
     @ondragover:preventDefault
     @ondragover="OnDragOver"
     @ondragleave="OnDragLeave"
     @ondrop="OnDrop">

    @* Column header *@
    <div class="flex items-center gap-1 border-b border-zinc-800 px-2 py-2">
        @* Color dot — click to recolor *@
        <div class="relative flex-shrink-0">
            <div class="h-2.5 w-2.5 rounded-full cursor-pointer hover:ring-2 hover:ring-zinc-500 transition-all"
                 style="background-color: @Column.Color"
                 @onclick="ToggleColorPicker"
                 title="Change color"></div>
            @if (_showColorPicker)
            {
                <div class="absolute left-0 top-5 z-50 rounded border border-zinc-700 bg-zinc-900 p-2 shadow-xl"
                     @onclick:stopPropagation>
                    <div class="flex flex-wrap gap-1.5 w-32">
                        @foreach (var color in _presetColors)
                        {
                            <div class="h-5 w-5 rounded-full cursor-pointer hover:ring-2 hover:ring-white/60 transition-all @(Column.Color == color ? "ring-2 ring-white/60" : "")"
                                 style="background-color: @color"
                                 @onclick="() => PickColor(color)"></div>
                        }
                    </div>
                    <input type="color" class="mt-1.5 w-full h-6 cursor-pointer rounded border-0"
                           value="@Column.Color"
                           @onchange="OnColorInputChange" />
                </div>
            }
        </div>

        @* Title — double-click to rename *@
        @if (_renaming)
        {
            <input class="flex-1 bg-transparent text-xs font-semibold text-zinc-200 focus:outline-none border-b border-blue-500 min-w-0 uppercase tracking-wide"
                   @bind="_renameValue" @bind:event="oninput"
                   @onkeydown="OnRenameKeyDown"
                   @onblur="CommitRename"
                   @ref="_renameInput" />
        }
        else
        {
            <span class="flex-1 font-semibold text-zinc-300 text-xs tracking-wide uppercase truncate cursor-default select-none"
                  @ondblclick="StartRename"
                  title="Double-click to rename">@Column.Title</span>
        }

        <span class="rounded bg-zinc-800 px-1.5 py-0.5 text-xs text-zinc-500 flex-shrink-0">@Column.Cards.Count</span>

        @* Move left/right *@
        <button class="flex-shrink-0 px-0.5 text-zinc-700 hover:text-zinc-400 text-xs leading-none transition-colors"
                title="Move left" @onclick="() => MoveColumn(-1)">←</button>
        <button class="flex-shrink-0 px-0.5 text-zinc-700 hover:text-zinc-400 text-xs leading-none transition-colors"
                title="Move right" @onclick="() => MoveColumn(1)">→</button>

        @* Delete column *@
        <button class="flex-shrink-0 text-zinc-700 hover:text-red-500 text-xs leading-none transition-colors"
                title="Delete column" @onclick="OnDeleteColumn">✕</button>
    </div>

    @* Card list *@
    <div class="flex flex-col gap-2 overflow-y-auto p-2 flex-1">
        @if (IsLoadingSkeleton)
        {
            @for (int i = 0; i < 3; i++)
            {
                <div class="h-16 animate-pulse rounded border border-zinc-700 bg-zinc-800"></div>
            }
        }
        else
        {
            @foreach (var card in Column.Cards.OrderBy(c => c.Position))
            {
                <CardItem Card="card"
                          IsDragging="DraggingCardId == card.Id"
                          OnDragStarted="OnCardDragStart"
                          OnDragEnded="OnCardDragEnd"
                          OnCardClicked="OnCardClicked" />
            }

            @if (IsDragOver && !Column.Cards.Any())
            {
                <div class="h-16 rounded border border-dashed border-blue-500/40 bg-blue-500/5
                            flex items-center justify-center text-xs text-blue-500/60">
                    drop here
                </div>
            }
        }
    </div>

    @* Add card button *@
    <button class="mx-2 mb-2 rounded border border-dashed border-zinc-800 py-1.5 text-xs text-zinc-600
                   hover:border-zinc-700 hover:text-zinc-400 transition-colors"
            @onclick="OnAddCard">
        + add card
    </button>
</div>

@code {
    [Parameter, EditorRequired] public ColumnWithCardsDto Column { get; set; } = null!;
    [Parameter] public int? DraggingCardId { get; set; }
    [Parameter] public bool IsLoadingSkeleton { get; set; }
    [Parameter] public EventCallback<CardDto> OnDragStarted { get; set; }
    [Parameter] public EventCallback OnDragEnded { get; set; }
    [Parameter] public EventCallback<(int ColumnId, int Position)> OnDropped { get; set; }
    [Parameter] public EventCallback<CardDto> CardClicked { get; set; }
    [Parameter] public EventCallback<int> AddCardRequested { get; set; }
    [Parameter] public EventCallback<int> DeleteRequested { get; set; }
    [Parameter] public EventCallback<(int ColumnId, string Title, string Color)> UpdateRequested { get; set; }
    [Parameter] public EventCallback<(int ColumnId, int Delta)> MoveRequested { get; set; }

    bool IsDragOver;
    bool _renaming;
    bool _showColorPicker;
    string _renameValue = "";
    ElementReference _renameInput;

    static readonly string[] _presetColors =
    [
        "#3b82f6", "#8b5cf6", "#ec4899", "#f97316",
        "#eab308", "#22c55e", "#14b8a6", "#ef4444",
        "#6b7280", "#f8fafc"
    ];

    void OnDragOver(DragEventArgs _)  => IsDragOver = true;
    void OnDragLeave(DragEventArgs _) => IsDragOver = false;

    async Task OnDrop(DragEventArgs _)
    {
        IsDragOver = false;
        var pos = Column.Cards.Any() ? Column.Cards.Max(c => c.Position) + 1 : 0;
        await OnDropped.InvokeAsync((Column.Id, pos));
    }

    async Task OnCardDragStart(CardDto card) => await OnDragStarted.InvokeAsync(card);
    async Task OnCardDragEnd()               => await OnDragEnded.InvokeAsync();
    async Task OnCardClicked(CardDto card)   => await CardClicked.InvokeAsync(card);
    async Task OnAddCard()                   => await AddCardRequested.InvokeAsync(Column.Id);
    async Task OnDeleteColumn()              => await DeleteRequested.InvokeAsync(Column.Id);
    async Task MoveColumn(int delta)         => await MoveRequested.InvokeAsync((Column.Id, delta));

    void ToggleColorPicker() => _showColorPicker = !_showColorPicker;

    async Task PickColor(string color)
    {
        _showColorPicker = false;
        await UpdateRequested.InvokeAsync((Column.Id, Column.Title, color));
    }

    async Task OnColorInputChange(ChangeEventArgs e)
    {
        var color = e.Value?.ToString() ?? Column.Color;
        _showColorPicker = false;
        await UpdateRequested.InvokeAsync((Column.Id, Column.Title, color));
    }

    async Task StartRename()
    {
        _renaming = true;
        _renameValue = Column.Title;
        await Task.Yield();
        await _renameInput.FocusAsync();
    }

    async Task OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CommitRename();
        if (e.Key == "Escape") _renaming = false;
    }

    async Task CommitRename()
    {
        if (!_renaming) return;
        _renaming = false;
        var name = _renameValue.Trim();
        if (string.IsNullOrWhiteSpace(name) || name == Column.Title) return;
        await UpdateRequested.InvokeAsync((Column.Id, name, Column.Color));
    }
}
