@using System.Net.Http.Json
@using Microsoft.JSInterop
@using TaskOrchestrator.Shared.Contracts
@using TaskOrchestrator.Shared.Enums
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication

@inject HttpClient Http
@inject IJSRuntime JS
@inject IAccessTokenProvider TokenProvider
@inject IConfiguration Configuration

@if (Card is not null)
{
    <div class="fixed inset-0 z-40 flex justify-end" @onclick="Close">
        <div class="absolute inset-0 bg-background/50 backdrop-blur-sm"></div>

        <div class="relative z-50 flex h-full w-full max-w-xl flex-col glass-panel shadow-2xl border-l border-white/5 overflow-hidden"
             @onclick:stopPropagation>

            @* Header *@
            <div class="flex items-center gap-4 border-b border-white/5 px-6 py-5">
                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                    <span class="material-symbols-outlined">task</span>
                </div>
                <div class="flex-1 min-w-0">
                    @if (_editing)
                    {
                        <input class="w-full bg-transparent text-lg font-headline font-bold text-on-surface focus:outline-none border-b border-primary pb-0.5"
                               @bind="_editTitle" @bind:event="oninput" />
                    }
                    else
                    {
                        <h2 class="text-lg font-headline font-extrabold text-on-surface truncate">@Card.Title</h2>
                    }
                    <p class="text-xs text-on-surface-variant mt-0.5">Card #@Card.Id · v@Card.Version · updated @Card.UpdatedAtUtc.ToString("dd MMM HH:mm")</p>
                </div>
                <button class="p-2 hover:bg-white/10 rounded-full transition-colors flex-shrink-0" @onclick="Close">
                    <span class="material-symbols-outlined text-on-surface-variant">close</span>
                </button>
            </div>

            @* Scrollable content *@
            <div class="flex-1 overflow-y-auto px-6 py-6 space-y-6">

                @* Priority *@
                <section>
                    <label class="block text-[10px] font-bold text-on-surface-variant uppercase tracking-widest mb-3">Priority</label>
                    @if (_editing)
                    {
                        <select class="w-full bg-surface-container-high border border-outline-variant text-sm text-on-surface px-4 py-3 rounded-xl focus:border-primary focus:outline-none"
                                @bind="_editPriority">
                            @foreach (var p in Enum.GetValues<TaskPriority>())
                            {
                                <option value="@p">@p</option>
                            }
                        </select>
                    }
                    else
                    {
                        <div class="@PriorityButtonClass flex items-center justify-between px-4 py-3 rounded-xl border font-semibold text-sm">
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 rounded-full @PriorityDotClass"></span>
                                @Card.Priority
                            </div>
                        </div>
                    }
                </section>

                @* Description *@
                <section>
                    <label class="block text-[10px] font-bold text-on-surface-variant uppercase tracking-widest mb-3">Description</label>
                    @if (_editing)
                    {
                        <textarea class="w-full bg-surface-container-high border border-outline-variant rounded-xl px-4 py-3 text-sm text-on-surface resize-none focus:border-primary focus:outline-none"
                                  rows="4" @bind="_editDescription"></textarea>
                    }
                    else
                    {
                        <p class="text-sm text-on-surface-variant leading-relaxed whitespace-pre-wrap">
                            @(string.IsNullOrWhiteSpace(Card.Description) ? "No description." : Card.Description)
                        </p>
                    }
                </section>

                @* Attachments *@
                <section>
                    <div class="flex items-center justify-between mb-3">
                        <label class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                            Attachments (@Card.Attachments.Count)
                        </label>
                        <button class="text-xs font-bold text-primary hover:underline" @onclick="TriggerFilePicker">Add New</button>
                    </div>
                    <div class="space-y-2">
                        @foreach (var att in Card.Attachments)
                        {
                            <div class="group flex items-center gap-3 p-3 rounded-xl bg-surface-container-high hover:bg-surface-bright transition-colors">
                                <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center flex-shrink-0">
                                    <span class="material-symbols-outlined text-sm text-on-surface-variant">@GetAttachmentIcon(att.FileName)</span>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-medium text-on-surface truncate">@att.FileName</p>
                                    <p class="text-[10px] text-on-surface-variant">@FormatSize(att.FileSizeBytes)</p>
                                </div>
                                <button class="opacity-0 group-hover:opacity-100 transition-opacity text-on-surface-variant hover:text-error"
                                        @onclick="() => DownloadAttachment(att)" title="Download">
                                    <span class="material-symbols-outlined text-base">download</span>
                                </button>
                            </div>
                        }
                    </div>

                    @* Upload area *@
                    <div class="mt-3 rounded-xl border-2 border-dashed border-outline-variant hover:border-primary/50 p-4 text-center
                                hover:bg-primary/5 transition-all cursor-pointer"
                         @onclick="TriggerFilePicker">
                        @if (_uploading)
                        {
                            <div class="flex items-center justify-center gap-2 text-xs text-on-surface-variant">
                                <span class="animate-spin material-symbols-outlined text-lg">autorenew</span>
                                Uploading...
                            </div>
                        }
                        else
                        {
                            <div class="flex items-center justify-center gap-2 text-xs text-on-surface-variant">
                                <span class="material-symbols-outlined text-lg">cloud_upload</span>
                                Drop file, paste, or <span class="text-primary ml-1">browse</span>
                            </div>
                        }
                    </div>
                    <InputFile id="@_fileInputId" @ref="_inputFile" class="hidden" OnChange="OnFileSelected" />
                    @if (_uploadError is not null)
                    {
                        <p class="mt-1 text-xs text-error">@_uploadError</p>
                    }
                </section>

                @* Activity *@
                <section>
                    <label class="block text-[10px] font-bold text-on-surface-variant uppercase tracking-widest mb-4">Activity</label>
                    <div class="space-y-4 relative ml-2">
                        <div class="absolute left-0 top-1 bottom-1 w-px bg-outline-variant/30"></div>
                        @foreach (var evt in _activity)
                        {
                            <div class="relative pl-5">
                                <div class="absolute left-[-4px] top-1.5 w-2 h-2 rounded-full bg-surface-container-highest ring-4 ring-surface-container-highest border border-outline-variant/50"></div>
                                <p class="text-xs text-on-surface leading-relaxed">
                                    <span class="font-semibold">@(evt.UserDisplayName ?? "System")</span>
                                    · @evt.Description
                                </p>
                                <p class="text-[10px] text-on-surface-variant mt-0.5 uppercase font-bold tracking-tighter">
                                    @evt.OccurredAtUtc.ToString("MMM dd, HH:mm")
                                </p>
                            </div>
                        }
                        @if (!_activity.Any())
                        {
                            <p class="text-xs text-on-surface-variant pl-5">No activity yet.</p>
                        }
                    </div>
                </section>

            </div>

            @* Footer *@
            <div class="border-t border-white/5 px-6 py-4 bg-surface-container-lowest flex items-center gap-3">
                @if (_saveError is not null)
                {
                    <p class="mr-auto text-xs text-error">@_saveError</p>
                }
                @if (_editing)
                {
                    <button class="flex-1 rounded-xl border border-outline-variant px-4 py-3 text-sm font-headline font-bold text-on-surface-variant hover:bg-white/5 transition-colors"
                            @onclick="CancelEdit">Cancel</button>
                    <button class="flex-1 btn-gradient rounded-xl px-4 py-3 text-sm font-headline font-bold text-white hover:opacity-90 transition-all"
                            @onclick="SaveEdit">Save Changes</button>
                }
                else
                {
                    <button class="flex-1 rounded-xl border border-outline-variant px-4 py-3 text-sm font-headline font-bold text-on-surface-variant hover:bg-white/5 transition-colors"
                            @onclick="Close">Cancel</button>
                    <button class="flex-1 btn-gradient rounded-xl px-4 py-3 text-sm font-headline font-bold text-white hover:opacity-90 transition-all"
                            @onclick="StartEdit">Edit</button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public CardDto? Card { get; set; }
    [Parameter] public EventCallback OnClosed { get; set; }
    [Parameter] public EventCallback<CardDto> OnSaved { get; set; }
    [Parameter] public EventCallback<AttachmentDto> OnAttachmentUploaded { get; set; }

    InputFile? _inputFile;
    bool _editing, _uploading;
    string? _uploadError;
    string? _saveError;
    string _editTitle = "";
    string? _editDescription;
    TaskPriority _editPriority;
    List<ActivityEventDto> _activity = [];
    readonly string _fileInputId = $"attachment-input-{Guid.NewGuid():N}";

    protected override async Task OnParametersSetAsync()
    {
        if (Card is null) return;
        _editTitle = Card.Title;
        _editDescription = Card.Description;
        _editPriority = Card.Priority;
        await LoadActivityAsync();
    }

    async Task LoadActivityAsync()
    {
        if (Card is null) return;
        try
        {
            _activity = await Http.GetFromJsonAsync<List<ActivityEventDto>>(
                $"/api/cards/{Card.Id}/activity") ?? [];
        }
        catch
        {
            _activity = [];
        }
    }

    void StartEdit()
    {
        _editing = true;
        _editTitle = Card?.Title ?? "";
        _editDescription = Card?.Description;
        _editPriority = Card?.Priority ?? TaskPriority.Medium;
    }

    void CancelEdit() => _editing = false;

    async Task SaveEdit()
    {
        if (Card is null) return;
        _saveError = null;
        var req = new UpdateCardRequest(_editTitle, _editDescription, _editPriority, Card.AssignedToUserId, null, Card.Version);
        var response = await Http.PatchAsJsonAsync($"/api/cards/{Card.Id}", req);
        if (response.IsSuccessStatusCode)
        {
            var updated = await response.Content.ReadFromJsonAsync<CardDto>();
            if (updated is not null) await OnSaved.InvokeAsync(updated);
            _editing = false;
        }
        else
        {
            _saveError = $"Save failed ({(int)response.StatusCode})";
        }
    }

    async Task TriggerFilePicker() => await JS.InvokeVoidAsync("attachmentInterop.clickById", _fileInputId);

    async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _uploadError = null;
        _uploading = true;
        StateHasChanged();

        try
        {
            var file = e.File;
            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
            using var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync($"/api/cards/{Card!.Id}/attachments", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadAttachmentResponse>();
                if (result?.Attachment is not null)
                    await OnAttachmentUploaded.InvokeAsync(result.Attachment);
            }
            else
            {
                _uploadError = $"Upload failed ({(int)response.StatusCode})";
            }
        }
        catch (Exception ex)
        {
            _uploadError = ex.Message;
        }
        finally
        {
            _uploading = false;
        }
    }

    // Called from Board.razor via JS interop paste handler
    [JSInvokable]
    public async Task ReceiveFilePaste(string name, string type, string base64)
    {
        if (Card is null) return;
        _uploadError = null;
        _uploading = true;
        StateHasChanged();
        try
        {
            var bytes = Convert.FromBase64String(base64);
            using var content = new MultipartFormDataContent();
            using var fileContent = new ByteArrayContent(bytes);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(string.IsNullOrWhiteSpace(type) ? "application/octet-stream" : type);
            content.Add(fileContent, "file", name);
            var response = await Http.PostAsync($"/api/cards/{Card.Id}/attachments", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadAttachmentResponse>();
                if (result?.Attachment is not null)
                    await OnAttachmentUploaded.InvokeAsync(result.Attachment);
            }
            else
            {
                _uploadError = $"Upload failed ({(int)response.StatusCode})";
            }
        }
        catch (Exception ex)
        {
            _uploadError = ex.Message;
        }
        finally { _uploading = false; StateHasChanged(); }
    }

    async Task DownloadAttachment(AttachmentDto att)
    {
        var result = await TokenProvider.RequestAccessToken();
        if (!result.TryGetToken(out var token)) return;
        var apiBase = Configuration["ApiBaseUrl"] ?? "http://localhost:5041";
        var url = att.Url.StartsWith("http") ? att.Url : $"{apiBase}{att.Url}";
        await JS.InvokeVoidAsync("downloadFileWithAuth", url, token.Value, att.FileName);
    }

    async Task Close() => await OnClosed.InvokeAsync();

    static string FormatSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes}B",
        < 1024 * 1024 => $"{bytes / 1024}KB",
        _ => $"{bytes / 1024 / 1024}MB"
    };

    string PriorityButtonClass => Card?.Priority switch
    {
        TaskPriority.Critical => "bg-error-container text-on-error-container border-error/20",
        TaskPriority.High     => "bg-tertiary-container/20 text-tertiary border-tertiary/20",
        TaskPriority.Medium   => "bg-secondary-container/20 text-secondary border-secondary/20",
        _ => "bg-surface-container-high text-on-surface-variant border-outline-variant"
    };

    string PriorityDotClass => Card?.Priority switch
    {
        TaskPriority.Critical => "bg-error animate-pulse",
        TaskPriority.High     => "bg-tertiary",
        TaskPriority.Medium   => "bg-secondary",
        _ => "bg-on-surface-variant"
    };

    static string GetAttachmentIcon(string fileName)
    {
        var ext = System.IO.Path.GetExtension(fileName).ToLowerInvariant();
        return ext switch
        {
            ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp" => "image",
            ".pdf" => "picture_as_pdf",
            ".txt" or ".md" => "description",
            ".zip" => "folder_zip",
            _ => "attach_file"
        };
    }
}
