@using System.Net.Http.Json
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using TaskOrchestrator.Shared.Contracts
@using TaskOrchestrator.Shared.Enums

@inject HttpClient Http
@inject IJSRuntime JS
@inject IAccessTokenProvider TokenProvider
@inject IConfiguration Configuration

@if (Card is not null)
{
    <div class="fixed inset-0 z-40 flex justify-end" @onclick="Close">
        @* Backdrop *@
        <div class="absolute inset-0 bg-black/50"></div>

        @* Drawer *@
        <div class="relative z-50 flex h-full w-full max-w-md flex-col border-l border-zinc-800 bg-zinc-950 shadow-2xl overflow-hidden"
             @onclick:stopPropagation>

            @* Header *@
            <div class="flex items-center gap-3 border-b border-zinc-800 px-4 py-3">
                <div class="flex-1 min-w-0">
                    @if (_editing)
                    {
                        <input class="w-full bg-transparent text-base font-semibold text-zinc-100 focus:outline-none border-b border-blue-500 pb-0.5"
                               @bind="_editTitle" @bind:event="oninput" />
                    }
                    else
                    {
                        <h2 class="truncate text-base font-semibold text-zinc-100">@Card.Title</h2>
                    }
                    <p class="text-xs text-zinc-600 mt-0.5">
                        Card #@Card.Id · v@Card.Version ·
                        updated @Card.UpdatedAtUtc.ToString("dd MMM HH:mm")
                    </p>
                </div>
                <button class="text-zinc-600 hover:text-zinc-300 transition-colors text-lg leading-none"
                        @onclick="Close">✕</button>
            </div>

            <div class="flex flex-1 flex-col overflow-y-auto">
                @* Description *@
                <div class="border-b border-zinc-800 px-4 py-3">
                    <label class="text-[10px] uppercase tracking-wider text-zinc-600 font-semibold">Description</label>
                    @if (_editing)
                    {
                        <textarea class="mt-1 w-full resize-none bg-zinc-900 rounded border border-zinc-700 px-2 py-1.5
                                         text-sm text-zinc-300 focus:border-blue-500 focus:outline-none"
                                  rows="4"
                                  @bind="_editDescription"></textarea>
                    }
                    else
                    {
                        <p class="mt-1 text-sm text-zinc-400 whitespace-pre-wrap">
                            @(string.IsNullOrWhiteSpace(Card.Description) ? "No description." : Card.Description)
                        </p>
                    }
                </div>

                @* Priority + assigned *@
                <div class="flex gap-4 border-b border-zinc-800 px-4 py-3">
                    <div class="flex-1">
                        <label class="text-[10px] uppercase tracking-wider text-zinc-600 font-semibold">Priority</label>
                        @if (_editing)
                        {
                            <select class="mt-1 w-full bg-zinc-900 rounded border border-zinc-700 px-2 py-1
                                           text-sm text-zinc-300 focus:border-blue-500 focus:outline-none"
                                    @bind="_editPriority">
                                @foreach (var p in Enum.GetValues<TaskPriority>())
                                {
                                    <option value="@p">@p</option>
                                }
                            </select>
                        }
                        else
                        {
                            <p class="mt-1 text-sm @PriorityColor(Card.Priority)">@Card.Priority</p>
                        }
                    </div>
                </div>

                @* Attachments *@
                <div class="border-b border-zinc-800 px-4 py-3">
                    <label class="text-[10px] uppercase tracking-wider text-zinc-600 font-semibold">
                        Attachments (@Card.Attachments.Count)
                    </label>
                    <div class="mt-2 flex flex-col gap-1">
                        @foreach (var att in Card.Attachments)
                        {
                            <button @onclick="() => DownloadAttachment(att)"
                               class="flex items-center gap-2 rounded border border-zinc-800 bg-zinc-900 px-2 py-1.5
                                      text-xs text-zinc-400 hover:text-zinc-200 hover:border-zinc-700 transition-colors">
                                <span>⊟</span>
                                <span class="flex-1 truncate">@att.FileName</span>
                                <span class="text-zinc-600">@FormatSize(att.FileSizeBytes)</span>
                            </button>
                        }
                    </div>

                    @* Upload area *@
                    <div class="mt-2 rounded border border-dashed border-zinc-700 p-3 text-center
                                hover:border-zinc-600 transition-colors cursor-pointer"
                         @onclick="TriggerFilePicker">
                        @if (_uploading)
                        {
                            <div class="flex items-center justify-center gap-2 text-xs text-zinc-500">
                                <span class="animate-spin">⟳</span> Uploading...
                            </div>
                        }
                        else
                        {
                            <p class="text-xs text-zinc-600">drop file, paste, or <span class="text-blue-500 cursor-pointer">browse</span></p>
                        }
                    </div>
                    <InputFile id="@_fileInputId" @ref="_inputFile" class="hidden" OnChange="OnFileSelected" />
                    @if (_uploadError is not null)
                    {
                        <p class="mt-1 text-xs text-red-400">@_uploadError</p>
                    }
                </div>

                @* Activity *@
                <div class="px-4 py-3 flex-1">
                    <label class="text-[10px] uppercase tracking-wider text-zinc-600 font-semibold mb-2 block">Activity</label>
                    <ActivityFeed Events="@_activity" />
                </div>
            </div>

            @* Footer actions *@
            <div class="border-t border-zinc-800 px-4 py-3 flex gap-2 justify-end">
                @if (_saveError is not null)
                {
                    <p class="mr-auto self-center text-xs text-red-400">@_saveError</p>
                }
                @if (_editing)
                {
                    <button class="rounded border border-zinc-700 px-3 py-1.5 text-xs text-zinc-400
                                   hover:border-zinc-600 hover:text-zinc-200 transition-colors"
                            @onclick="CancelEdit">Cancel</button>
                    <button class="rounded border border-blue-700 bg-blue-900/40 px-3 py-1.5 text-xs text-blue-300
                                   hover:bg-blue-900/60 transition-colors"
                            @onclick="SaveEdit">Save</button>
                }
                else
                {
                    <button class="rounded border border-zinc-700 px-3 py-1.5 text-xs text-zinc-400
                                   hover:border-zinc-600 hover:text-zinc-200 transition-colors"
                            @onclick="StartEdit">Edit</button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public CardDto? Card { get; set; }
    [Parameter] public EventCallback OnClosed { get; set; }
    [Parameter] public EventCallback<CardDto> OnSaved { get; set; }
    [Parameter] public EventCallback<AttachmentDto> OnAttachmentUploaded { get; set; }

    InputFile? _inputFile;
    bool _editing, _uploading;
    string? _uploadError;
    string? _saveError;
    string _editTitle = "";
    string? _editDescription;
    TaskPriority _editPriority;
    List<ActivityEventDto> _activity = [];
    readonly string _fileInputId = $"attachment-input-{Guid.NewGuid():N}";

    protected override async Task OnParametersSetAsync()
    {
        if (Card is null) return;
        _editTitle = Card.Title;
        _editDescription = Card.Description;
        _editPriority = Card.Priority;
        await LoadActivityAsync();
    }

    async Task LoadActivityAsync()
    {
        if (Card is null) return;
        try
        {
            _activity = await Http.GetFromJsonAsync<List<ActivityEventDto>>(
                $"/api/cards/{Card.Id}/activity") ?? [];
        }
        catch
        {
            _activity = [];
        }
    }

    void StartEdit()
    {
        _editing = true;
        _editTitle = Card?.Title ?? "";
        _editDescription = Card?.Description;
        _editPriority = Card?.Priority ?? TaskPriority.Medium;
    }

    void CancelEdit() => _editing = false;

    async Task SaveEdit()
    {
        if (Card is null) return;
        _saveError = null;
        var req = new UpdateCardRequest(_editTitle, _editDescription, _editPriority, Card.AssignedToUserId, null, Card.Version);
        var response = await Http.PatchAsJsonAsync($"/api/cards/{Card.Id}", req);
        if (response.IsSuccessStatusCode)
        {
            var updated = await response.Content.ReadFromJsonAsync<CardDto>();
            if (updated is not null) await OnSaved.InvokeAsync(updated);
            _editing = false;
        }
        else
        {
            _saveError = $"Save failed ({(int)response.StatusCode})";
        }
    }

    async Task TriggerFilePicker() => await JS.InvokeVoidAsync("attachmentInterop.clickById", _fileInputId);

    async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _uploadError = null;
        _uploading = true;
        StateHasChanged();

        try
        {
            var file = e.File;
            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
            using var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync($"/api/cards/{Card!.Id}/attachments", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadAttachmentResponse>();
                if (result?.Attachment is not null)
                    await OnAttachmentUploaded.InvokeAsync(result.Attachment);
            }
            else
            {
                _uploadError = $"Upload failed ({(int)response.StatusCode})";
            }
        }
        catch (Exception ex)
        {
            _uploadError = ex.Message;
        }
        finally
        {
            _uploading = false;
        }
    }

    // Called from Board.razor via JS interop paste handler
    [JSInvokable]
    public async Task ReceiveFilePaste(string name, string type, string base64)
    {
        if (Card is null) return;
        _uploadError = null;
        _uploading = true;
        StateHasChanged();
        try
        {
            var bytes = Convert.FromBase64String(base64);
            using var content = new MultipartFormDataContent();
            using var fileContent = new ByteArrayContent(bytes);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(string.IsNullOrWhiteSpace(type) ? "application/octet-stream" : type);
            content.Add(fileContent, "file", name);
            var response = await Http.PostAsync($"/api/cards/{Card.Id}/attachments", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadAttachmentResponse>();
                if (result?.Attachment is not null)
                    await OnAttachmentUploaded.InvokeAsync(result.Attachment);
            }
            else
            {
                _uploadError = $"Upload failed ({(int)response.StatusCode})";
            }
        }
        catch (Exception ex)
        {
            _uploadError = ex.Message;
        }
        finally { _uploading = false; StateHasChanged(); }
    }

    async Task DownloadAttachment(AttachmentDto att)
    {
        var result = await TokenProvider.RequestAccessToken();
        if (!result.TryGetToken(out var token)) return;
        var apiBase = Configuration["ApiBaseUrl"] ?? "http://localhost:5041";
        var url = att.Url.StartsWith("http") ? att.Url : $"{apiBase}{att.Url}";
        await JS.InvokeVoidAsync("downloadFileWithAuth", url, token.Value, att.FileName);
    }

    async Task Close() => await OnClosed.InvokeAsync();

    static string FormatSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes}B",
        < 1024 * 1024 => $"{bytes / 1024}KB",
        _ => $"{bytes / 1024 / 1024}MB"
    };

    static string PriorityColor(TaskPriority p) => p switch
    {
        TaskPriority.Critical => "text-red-400",
        TaskPriority.High     => "text-orange-400",
        TaskPriority.Medium   => "text-blue-400",
        _                     => "text-zinc-500"
    };
}
