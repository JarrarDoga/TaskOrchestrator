@using TaskOrchestrator.Client.Services
@using TaskOrchestrator.Shared.Contracts

@if (Conflict is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm">
        <div class="w-full max-w-lg rounded-lg border border-red-900/50 bg-zinc-900 p-5 shadow-2xl">
            <div class="mb-4 flex items-start gap-3">
                <span class="text-red-400 text-lg">⚠</span>
                <div>
                    <h3 class="font-semibold text-zinc-100">Edit Conflict</h3>
                    <p class="mt-1 text-sm text-zinc-400">@Conflict.Message</p>
                </div>
            </div>

            @if (Conflict.ServerSnapshot is not null && Conflict.LocalVersion is not null)
            {
                <div class="mt-3 grid grid-cols-2 gap-3 text-xs">
                    <div class="rounded border border-zinc-700 bg-zinc-800/60 p-3">
                        <p class="mb-1 font-semibold text-zinc-500 uppercase tracking-wider text-[10px]">Server (current)</p>
                        <p class="text-zinc-200">@Conflict.ServerSnapshot.Title</p>
                        <p class="text-zinc-500 mt-1 line-clamp-2">@Conflict.ServerSnapshot.Description</p>
                        <p class="mt-1 text-zinc-600">v@Conflict.ServerSnapshot.Version</p>
                    </div>
                    <div class="rounded border border-blue-800/40 bg-zinc-800/60 p-3">
                        <p class="mb-1 font-semibold text-zinc-500 uppercase tracking-wider text-[10px]">Your version</p>
                        <p class="text-zinc-200">@Conflict.LocalVersion.Title</p>
                        <p class="text-zinc-500 mt-1 line-clamp-2">@Conflict.LocalVersion.Description</p>
                        <p class="mt-1 text-zinc-600">v@Conflict.LocalVersion.Version</p>
                    </div>
                </div>
            }

            <div class="mt-5 flex gap-2 justify-end">
                <button class="rounded border border-zinc-700 px-3 py-1.5 text-sm text-zinc-400
                               hover:border-zinc-600 hover:text-zinc-200 transition-colors"
                        @onclick="() => Dismissed.InvokeAsync(ConflictResolution.Discard)">
                    Discard my changes
                </button>
                <button class="rounded border border-blue-700 bg-blue-900/40 px-3 py-1.5 text-sm text-blue-300
                               hover:bg-blue-900/60 transition-colors"
                        @onclick="() => Dismissed.InvokeAsync(ConflictResolution.RetryWithServer)">
                    Use server version
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public ConflictInfo? Conflict { get; set; }
    [Parameter] public EventCallback<ConflictResolution> Dismissed { get; set; }
}
