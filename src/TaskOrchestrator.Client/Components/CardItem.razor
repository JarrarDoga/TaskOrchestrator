@using TaskOrchestrator.Shared.Contracts
@using TaskOrchestrator.Shared.Enums

<div class="group bg-surface-container-highest rounded-xl p-4 border-l-4 @(IsDragging ? "opacity-40 scale-95 border-transparent" : "border-transparent hover:border-primary") hover:bg-surface-bright transition-all duration-150 cursor-pointer shadow-sm select-none"
     draggable="true"
     @ondragstart="OnDragStart"
     @ondragend="OnDragEnd"
     @onclick="OnClick">

    @* Priority badge + menu *@
    <div class="flex items-center justify-between mb-2">
        <span class="@PriorityBadgeClass text-[10px] font-bold uppercase px-2 py-0.5 rounded-full tracking-wider">
            @Card.Priority
        </span>
        <span class="material-symbols-outlined text-outline group-hover:text-on-surface-variant text-lg opacity-0 group-hover:opacity-100 transition-opacity">more_horiz</span>
    </div>

    @* Title *@
    <h4 class="text-sm font-semibold text-on-surface mb-1 line-clamp-2 leading-snug">@Card.Title</h4>

    @* Description *@
    @if (!string.IsNullOrWhiteSpace(Card.Description))
    {
        <p class="text-xs text-on-surface-variant line-clamp-2 mb-3 leading-relaxed">@Card.Description</p>
    }

    @* Meta row *@
    <div class="flex items-center justify-between mt-2">
        <div class="flex items-center gap-3 text-[10px] text-outline">
            @if (Card.Attachments.Any())
            {
                <div class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-sm">attach_file</span>
                    <span>@Card.Attachments.Count</span>
                </div>
            }
            @foreach (var label in Labels.Take(2))
            {
                <span class="rounded-full bg-primary/10 px-1.5 py-0.5 text-primary text-[9px] font-bold uppercase">@label</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(Card.AssignedToUserId))
        {
            <div class="h-6 w-6 rounded-full bg-surface-container flex items-center justify-center text-[9px] font-bold text-on-surface-variant border border-outline-variant/30"
                 title="@Card.AssignedToUserId">
                @Card.AssignedToUserId[..1].ToUpper()
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public CardDto Card { get; set; } = null!;
    [Parameter] public bool IsDragging { get; set; }
    [Parameter] public EventCallback<CardDto> OnDragStarted { get; set; }
    [Parameter] public EventCallback OnDragEnded { get; set; }
    [Parameter] public EventCallback<CardDto> OnCardClicked { get; set; }

    string PriorityBadgeClass => Card.Priority switch
    {
        TaskPriority.Critical => "bg-error-container text-on-error-container",
        TaskPriority.High     => "bg-tertiary-container/40 text-tertiary",
        TaskPriority.Medium   => "bg-secondary-container text-on-secondary-container",
        _                     => "bg-surface-container-high text-on-surface-variant"
    };

    IEnumerable<string> Labels
    {
        get
        {
            if (Card.Metadata.TryGetValue("labels", out var el)
                && el.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var item in el.EnumerateArray())
                    yield return item.GetString() ?? "";
            }
        }
    }

    async Task OnDragStart(DragEventArgs e) => await OnDragStarted.InvokeAsync(Card);
    async Task OnDragEnd(DragEventArgs e)   => await OnDragEnded.InvokeAsync();
    async Task OnClick()                    => await OnCardClicked.InvokeAsync(Card);
}
