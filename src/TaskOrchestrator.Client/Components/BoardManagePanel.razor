@using System.Net.Http.Json
@using TaskOrchestrator.Shared.Contracts
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

@if (BoardId.HasValue)
{
    <div class="fixed inset-0 z-50 flex justify-end" @onclick="Close">
        <div class="absolute inset-0 bg-background/50 backdrop-blur-sm"></div>
        <div class="relative z-50 flex h-full w-[450px] flex-col glass-panel shadow-2xl border-l border-white/5"
             @onclick:stopPropagation>

            @* Header *@
            <div class="px-8 py-6 border-b border-white/5 flex items-center justify-between flex-shrink-0">
                <div>
                    <h2 class="text-2xl font-headline font-extrabold text-on-surface tracking-tight">Manage Board</h2>
                    <p class="text-on-surface-variant text-sm mt-0.5">Board #@BoardId</p>
                </div>
                <button class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-white/10 transition-colors"
                        @onclick="Close">
                    <span class="material-symbols-outlined text-on-surface-variant">close</span>
                </button>
            </div>

            <div class="flex-1 overflow-y-auto px-8 py-6 space-y-10">
                @* Invite Code *@
                <section class="space-y-4">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-xl">key</span>
                        <h3 class="font-headline font-bold text-on-surface">Invite Code</h3>
                    </div>
                    @if (_loadingInvite)
                    {
                        <p class="text-xs text-on-surface-variant">Loading…</p>
                    }
                    else if (_invite is not null)
                    {
                        <div class="p-4 rounded-xl bg-surface-container-low border border-outline-variant/15 space-y-3">
                            <div class="flex items-center gap-2">
                                <code class="flex-1 font-headline font-bold text-on-surface text-sm tracking-widest truncate">@_invite.Code</code>
                                <button class="text-on-surface-variant hover:text-primary transition-colors" @onclick="CopyInviteCode" title="Copy">
                                    <span class="material-symbols-outlined text-lg">content_copy</span>
                                </button>
                                <button class="text-on-surface-variant hover:text-error transition-colors" @onclick="RevokeInvite" title="Revoke">
                                    <span class="material-symbols-outlined text-lg">delete</span>
                                </button>
                            </div>
                            <div class="flex gap-3 text-[10px] text-on-surface-variant font-bold uppercase tracking-wider">
                                @if (_invite.ExpiresAt.HasValue) { <span>Expires @_invite.ExpiresAt.Value.ToString("dd MMM yyyy")</span> }
                                else { <span>No expiry</span> }
                                <span>Uses: @_invite.TimesUsed@(_invite.MaxUses.HasValue ? $" / {_invite.MaxUses}" : "")</span>
                            </div>
                            @if (_copySuccess) { <p class="text-xs text-secondary font-medium">Copied to clipboard!</p> }
                        </div>
                    }
                    else
                    {
                        <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant/15 flex flex-col items-center gap-4 text-center">
                            <p class="text-sm text-on-surface-variant">No active invite code</p>
                        </div>
                    }
                    @if (_inviteError is not null) { <p class="text-xs text-error">@_inviteError</p> }
                    <button class="w-full btn-gradient text-white py-3 rounded-xl font-headline font-extrabold text-sm transition-all hover:opacity-90 active:scale-[0.98]"
                            @onclick="GenerateInvite">
                        @(_invite is null ? "Generate invite code" : "Regenerate")
                    </button>
                </section>

                @* Members *@
                <section class="space-y-4">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-xl">group</span>
                            <h3 class="font-headline font-bold text-on-surface">Members</h3>
                        </div>
                        <span class="text-[10px] font-bold text-primary bg-primary/10 px-2 py-1 rounded-full uppercase tracking-wider">
                            @_members.Count Members
                        </span>
                    </div>
                    @if (_loadingMembers)
                    {
                        <p class="text-xs text-on-surface-variant">Loading…</p>
                    }
                    else
                    {
                        <div class="space-y-2">
                            @foreach (var m in _members)
                            {
                                <div class="group flex items-center gap-4 p-4 rounded-xl bg-surface-container-high hover:bg-surface-bright transition-all border-l-2 border-transparent hover:border-primary">
                                    <div class="relative flex-shrink-0">
                                        @if (!string.IsNullOrEmpty(m.AvatarUrl))
                                        {
                                            <img src="@m.AvatarUrl" class="w-10 h-10 rounded-full object-cover @(m.Role == "Owner" ? "border-2 border-primary/30" : "opacity-70 grayscale group-hover:grayscale-0 group-hover:opacity-100 transition-all")" alt="@m.DisplayName" />
                                        }
                                        else
                                        {
                                            <div class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-sm font-headline font-bold @(m.Role == "Owner" ? "text-primary border-2 border-primary/30" : "text-on-surface-variant")">
                                                @m.DisplayName[..1].ToUpper()
                                            </div>
                                        }
                                        @if (m.Role == "Owner")
                                        {
                                            <div class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-secondary rounded-full border-2 border-surface-container-high"></div>
                                        }
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-semibold text-on-surface truncate">@m.DisplayName</p>
                                        <p class="text-[10px] font-bold @(m.Role == "Owner" ? "text-primary" : "text-on-surface-variant/60") uppercase tracking-widest mt-0.5">@m.Role</p>
                                        <p class="text-[10px] text-on-surface-variant/40">@FormatRelative(m.LastSeenAt)</p>
                                    </div>
                                    @if (m.Role != "Owner" && _currentUserRole == "Owner")
                                    {
                                        <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                            <button class="p-1.5 hover:bg-white/10 rounded-lg text-on-surface-variant hover:text-error transition-colors"
                                                    title="Remove" @onclick="() => KickMember(m.UserId)">
                                                <span class="material-symbols-outlined text-base">person_remove</span>
                                            </button>
                                            <button class="p-1.5 hover:bg-white/10 rounded-lg text-on-surface-variant hover:text-tertiary transition-colors"
                                                    title="Transfer ownership" @onclick="() => TransferOwnership(m.UserId)">
                                                <span class="material-symbols-outlined text-base">workspace_premium</span>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    @if (_memberError is not null) { <p class="text-xs text-error mt-2">@_memberError</p> }
                    <button class="w-full flex items-center justify-center gap-2 py-4 text-on-surface-variant hover:text-primary transition-colors text-sm font-medium border-t border-outline-variant/10"
                            @onclick="() => _showManualAdd = !_showManualAdd">
                        <span class="material-symbols-outlined text-lg">person_add</span>
                        Add member manually
                    </button>

                    @if (_showManualAdd)
                    {
                        <div class="space-y-3 p-3 rounded-xl bg-surface-container-low border border-outline-variant/20">
                            <input value="@_manualSearch" @oninput="OnManualSearchChanged"
                                   placeholder="Search member by name/email"
                                   class="w-full bg-transparent border-0 border-b border-outline-variant focus:border-primary text-on-surface py-2 placeholder:text-outline outline-none" />

                            @if (_manualSearchResults.Count > 0)
                            {
                                <div class="max-h-48 overflow-y-auto rounded-lg border border-outline-variant/20">
                                    @foreach (var result in _manualSearchResults)
                                    {
                                        var r = result;
                                        <button class="w-full flex items-center justify-between px-3 py-2 text-left hover:bg-surface-bright transition-colors"
                                                @onclick="() => AddMemberManually(r)">
                                            <div>
                                                <p class="text-sm text-on-surface">@r.DisplayName</p>
                                                <p class="text-xs text-on-surface-variant">@r.Email</p>
                                            </div>
                                            <span class="material-symbols-outlined text-on-surface-variant">add</span>
                                        </button>
                                    }
                                </div>
                            }
                            else if (_manualSearch.Length >= 2)
                            {
                                <p class="text-xs text-on-surface-variant">
                                    No existing user found. Use invite code to share access link.
                                </p>
                            }

                            @if (_manualMessage is not null)
                            {
                                <p class="text-xs text-on-surface-variant">@_manualMessage</p>
                            }
                        </div>
                    }
                </section>
            </div>

            @* Footer *@
            <div class="px-8 py-6 border-t border-white/5 bg-surface-container-lowest flex-shrink-0">
                @if (_showPermissions)
                {
                    <div class="mb-4 p-4 rounded-xl bg-surface-container-low border border-outline-variant/20 space-y-2">
                        <p class="text-xs font-bold uppercase tracking-wider text-on-surface-variant">Permissions Model</p>
                        <p class="text-xs text-on-surface-variant">Owners can invite, remove, and transfer ownership. Members can view and edit board content.</p>
                        <button class="w-full px-3 py-2 rounded-lg border border-outline-variant text-xs font-semibold text-on-surface hover:bg-white/5 transition-colors"
                                @onclick="CopyJoinLink">
                            Copy Join Link
                        </button>
                        <div class="pt-2 border-t border-outline-variant/20 space-y-2">
                            <p class="text-xs text-on-surface-variant">Send invite emails (comma-separated):</p>
                            <textarea @bind="_emailInviteInput"
                                      rows="2"
                                      placeholder="alice@company.com, bob@company.com"
                                      class="w-full rounded-lg border border-outline-variant bg-surface-container-high px-3 py-2 text-xs text-on-surface placeholder-on-surface-variant/50 focus:border-primary focus:outline-none"></textarea>
                            <button class="w-full px-3 py-2 rounded-lg btn-gradient text-white text-xs font-semibold disabled:opacity-50"
                                    disabled="@_sendingEmailInvites"
                                    @onclick="SendInviteEmails">
                                @(_sendingEmailInvites ? "Sending..." : "Send Invite Emails")
                            </button>
                            @if (_emailInviteMessage is not null)
                            {
                                <p class="text-xs text-on-surface-variant">@_emailInviteMessage</p>
                            }
                        </div>
                    </div>
                }
                <div class="flex gap-3">
                    <button class="flex-1 px-4 py-3 rounded-xl border border-outline-variant text-on-surface text-sm font-headline font-bold hover:bg-white/5 transition-colors"
                            @onclick="() => _showPermissions = !_showPermissions">
                        Permissions
                    </button>
                    <button class="flex-1 px-4 py-3 rounded-xl bg-error-container/20 text-error border border-error-container/30 text-sm font-headline font-bold hover:bg-error-container/30 transition-colors disabled:opacity-50"
                            @onclick="DeleteBoard"
                            disabled="@_deletingBoard">
                        @(_confirmDelete ? (_deletingBoard ? "Deleting..." : "Confirm Delete") : "Archive Board")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? BoardId { get; set; }
    [Parameter] public string? CurrentUserId { get; set; }
    [Parameter] public EventCallback OnClosed { get; set; }
    [Parameter] public EventCallback<int> OnBoardDeleted { get; set; }

    List<BoardMemberDto> _members = [];
    BoardInviteDto? _invite;
    string? _currentUserRole;
    bool _loadingMembers, _loadingInvite;
    string? _memberError, _inviteError;
    bool _copySuccess;
    bool _showManualAdd;
    bool _showPermissions;
    bool _deletingBoard;
    bool _confirmDelete;
    bool _sendingEmailInvites;

    string _manualSearch = "";
    string? _manualMessage;
    string _emailInviteInput = "";
    string? _emailInviteMessage;
    List<UserSearchDto> _manualSearchResults = [];
    System.Threading.CancellationTokenSource? _manualSearchCts;

    protected override async Task OnParametersSetAsync()
    {
        if (!BoardId.HasValue) return;
        _members = [];
        _invite = null;
        _memberError = null;
        _inviteError = null;
        _manualMessage = null;
        _manualSearch = "";
        _manualSearchResults = [];
        _emailInviteInput = "";
        _emailInviteMessage = null;
        _showManualAdd = false;
        _showPermissions = false;
        _confirmDelete = false;
        await Task.WhenAll(LoadMembers(), LoadInvite());
    }

    async Task LoadMembers()
    {
        _loadingMembers = true;
        try
        {
            _members = await Http.GetFromJsonAsync<List<BoardMemberDto>>(
                $"/api/boards/{BoardId}/members") ?? [];
            _currentUserRole = _members.FirstOrDefault(m => m.UserId == CurrentUserId)?.Role;
        }
        catch { _members = []; }
        _loadingMembers = false;
    }

    async Task LoadInvite()
    {
        _loadingInvite = true;
        try
        {
            var resp = await Http.GetAsync($"/api/boards/{BoardId}/invite");
            _invite = resp.IsSuccessStatusCode
                ? await resp.Content.ReadFromJsonAsync<BoardInviteDto>()
                : null;
        }
        catch { _invite = null; }
        _loadingInvite = false;
    }

    async Task GenerateInvite()
    {
        _inviteError = null;
        var resp = await Http.PostAsJsonAsync($"/api/boards/{BoardId}/invite",
            new GenerateInviteRequest(null, null));
        if (resp.IsSuccessStatusCode)
            _invite = await resp.Content.ReadFromJsonAsync<BoardInviteDto>();
        else
            _inviteError = $"Failed ({(int)resp.StatusCode})";
    }

    async Task RevokeInvite()
    {
        await Http.DeleteAsync($"/api/boards/{BoardId}/invite");
        _invite = null;
    }

    async Task CopyInviteCode()
    {
        if (_invite is null) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _invite.Code);
        _copySuccess = true;
        StateHasChanged();
        await Task.Delay(2000);
        _copySuccess = false;
        StateHasChanged();
    }

    async Task KickMember(string userId)
    {
        _memberError = null;
        var resp = await Http.DeleteAsync($"/api/boards/{BoardId}/members/{userId}");
        if (resp.IsSuccessStatusCode)
            _members.RemoveAll(m => m.UserId == userId);
        else
            _memberError = $"Could not remove ({(int)resp.StatusCode})";
    }

    async Task TransferOwnership(string newOwnerId)
    {
        _memberError = null;
        var resp = await Http.PostAsJsonAsync($"/api/boards/{BoardId}/transfer",
            new TransferOwnershipRequest(newOwnerId));
        if (resp.IsSuccessStatusCode)
            await LoadMembers();
        else
            _memberError = $"Transfer failed ({(int)resp.StatusCode})";
    }

    async Task OnManualSearchChanged(ChangeEventArgs e)
    {
        _manualSearch = e.Value?.ToString() ?? "";
        _manualMessage = null;

        _manualSearchCts?.Cancel();
        _manualSearchCts = new System.Threading.CancellationTokenSource();
        var token = _manualSearchCts.Token;

        if (_manualSearch.Length < 2)
        {
            _manualSearchResults = [];
            return;
        }

        try
        {
            await Task.Delay(250, token);
            var results = await Http.GetFromJsonAsync<List<UserSearchDto>>(
                $"/api/users/search?q={Uri.EscapeDataString(_manualSearch)}",
                token);

            var existing = _members.Select(m => m.UserId).ToHashSet();
            _manualSearchResults = (results ?? [])
                .Where(r => !existing.Contains(r.UserId))
                .ToList();
        }
        catch (OperationCanceledException)
        {
            // Ignore canceled searches.
        }
        catch
        {
            _manualSearchResults = [];
        }
    }

    async Task AddMemberManually(UserSearchDto user)
    {
        _memberError = null;
        _manualMessage = null;
        var resp = await Http.PostAsJsonAsync(
            $"/api/boards/{BoardId}/members",
            new AddBoardMemberRequest(user.UserId));

        if (!resp.IsSuccessStatusCode)
        {
            _memberError = $"Could not add member ({(int)resp.StatusCode}).";
            return;
        }

        await LoadMembers();
        _manualSearch = "";
        _manualSearchResults = [];
        _manualMessage = $"{user.DisplayName} added.";
    }

    async Task CopyJoinLink()
    {
        _inviteError = null;
        _manualMessage = null;

        if (_invite is null)
        {
            var resp = await Http.PostAsJsonAsync($"/api/boards/{BoardId}/invite",
                new GenerateInviteRequest(null, null));
            if (!resp.IsSuccessStatusCode)
            {
                _inviteError = $"Could not create invite ({(int)resp.StatusCode}).";
                return;
            }
            _invite = await resp.Content.ReadFromJsonAsync<BoardInviteDto>();
        }

        if (_invite is null) return;
        var joinUrl = $"{Nav.BaseUri.TrimEnd('/')}/join/{_invite.Code}";
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", joinUrl);
        _manualMessage = "Join link copied to clipboard.";
    }

    async Task SendInviteEmails()
    {
        _emailInviteMessage = null;
        var raw = _emailInviteInput?.Trim() ?? "";
        if (string.IsNullOrWhiteSpace(raw))
        {
            _emailInviteMessage = "Enter at least one email.";
            return;
        }

        _sendingEmailInvites = true;
        try
        {
            var resp = await Http.PostAsJsonAsync(
                $"/api/boards/{BoardId}/invite/email",
                new SendBoardInviteEmailRequest([raw]));

            if (!resp.IsSuccessStatusCode)
            {
                _emailInviteMessage = $"Invite send failed ({(int)resp.StatusCode}).";
                return;
            }

            var data = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
            var sent = data.TryGetProperty("sent", out var sentEl) ? sentEl.GetInt32() : 0;
            var failed = data.TryGetProperty("failed", out var failedEl) && failedEl.ValueKind == System.Text.Json.JsonValueKind.Array
                ? failedEl.GetArrayLength()
                : 0;

            _emailInviteMessage = failed == 0
                ? $"Sent {sent} invite email(s)."
                : $"Sent {sent} invite email(s), {failed} failed.";
            _emailInviteInput = "";
        }
        catch
        {
            _emailInviteMessage = "Failed to send invite emails.";
        }
        finally
        {
            _sendingEmailInvites = false;
        }
    }

    async Task DeleteBoard()
    {
        if (!BoardId.HasValue) return;

        _memberError = null;
        if (!_confirmDelete)
        {
            _confirmDelete = true;
            return;
        }

        _deletingBoard = true;
        var resp = await Http.DeleteAsync($"/api/boards/{BoardId.Value}");
        _deletingBoard = false;

        if (!resp.IsSuccessStatusCode)
        {
            _memberError = $"Could not delete board ({(int)resp.StatusCode}).";
            return;
        }

        await OnBoardDeleted.InvokeAsync(BoardId.Value);
        await Close();
    }

    static string FormatRelative(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 2) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("dd MMM");
    }

    async Task Close() => await OnClosed.InvokeAsync();
}
