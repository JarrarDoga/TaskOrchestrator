@using System.Net.Http.Json
@using TaskOrchestrator.Shared.Contracts
@inject HttpClient Http
@inject IJSRuntime JS

@if (BoardId.HasValue)
{
    <div class="fixed inset-0 z-50 flex justify-end" @onclick="Close">
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="relative z-50 flex h-full w-full max-w-lg flex-col border-l border-zinc-800 bg-zinc-950 shadow-2xl"
             @onclick:stopPropagation>

            <div class="flex items-center justify-between border-b border-zinc-800 px-4 py-3 flex-shrink-0">
                <h2 class="text-sm font-semibold text-zinc-200">Manage Board</h2>
                <button class="text-zinc-600 hover:text-zinc-300 text-lg leading-none" @onclick="Close">✕</button>
            </div>

            <div class="flex-1 overflow-y-auto">
                @* Invite code section *@
                <section class="border-b border-zinc-800 px-4 py-4">
                    <p class="text-[10px] uppercase tracking-widest text-zinc-500 mb-3">Invite Code</p>
                    @if (_loadingInvite)
                    {
                        <p class="text-xs text-zinc-600">Loading…</p>
                    }
                    else if (_invite is not null)
                    {
                        <div class="flex items-center gap-2 mb-2 flex-wrap">
                            <code class="flex-1 rounded border border-zinc-700 bg-zinc-900 px-3 py-1.5 text-sm text-zinc-100 tracking-widest font-mono min-w-0">
                                @_invite.Code
                            </code>
                            <button class="rounded border border-zinc-700 px-2 py-1.5 text-xs text-zinc-400 hover:text-zinc-200 transition-colors flex-shrink-0"
                                    @onclick="CopyInviteCode">⎘ Copy</button>
                            <button class="rounded border border-red-900 px-2 py-1.5 text-xs text-red-500 hover:text-red-300 transition-colors flex-shrink-0"
                                    @onclick="RevokeInvite">Revoke</button>
                        </div>
                        <div class="flex flex-wrap gap-3 text-xs text-zinc-600">
                            @if (_invite.ExpiresAt.HasValue)
                            { <span>Expires @_invite.ExpiresAt.Value.ToString("dd MMM yyyy")</span> }
                            else
                            { <span>No expiry</span> }
                            <span>Uses: @_invite.TimesUsed@(_invite.MaxUses.HasValue ? $" / {_invite.MaxUses}" : "")</span>
                        </div>
                        @if (_copySuccess) { <p class="mt-1 text-xs text-green-500">Copied!</p> }
                    }
                    else
                    {
                        <p class="text-xs text-zinc-600 mb-2">No active invite code.</p>
                    }
                    @if (_inviteError is not null) { <p class="text-xs text-red-400 mt-1">@_inviteError</p> }
                    <button class="mt-2 rounded border border-blue-700 bg-blue-900/30 px-3 py-1.5 text-xs text-blue-300 hover:bg-blue-900/50 transition-colors"
                            @onclick="GenerateInvite">
                        @(_invite is null ? "Generate invite code" : "Regenerate")
                    </button>
                </section>

                @* Members section *@
                <section class="px-4 py-4">
                    <p class="text-[10px] uppercase tracking-widest text-zinc-500 mb-3">Members (@_members.Count)</p>
                    @if (_loadingMembers)
                    {
                        <p class="text-xs text-zinc-600">Loading…</p>
                    }
                    else
                    {
                        <ul class="flex flex-col gap-2">
                            @foreach (var m in _members)
                            {
                                <li class="flex items-center gap-3 rounded border border-zinc-800 bg-zinc-900/60 px-3 py-2">
                                    @if (!string.IsNullOrEmpty(m.AvatarUrl))
                                    {
                                        <img src="@m.AvatarUrl" alt="@m.DisplayName"
                                             class="h-8 w-8 rounded-full object-cover flex-shrink-0" />
                                    }
                                    else
                                    {
                                        <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-zinc-700 text-xs font-bold text-zinc-300">
                                            @m.DisplayName[..1].ToUpper()
                                        </div>
                                    }
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm text-zinc-200 truncate">@m.DisplayName</p>
                                        <p class="text-[10px] text-zinc-600">Last seen @FormatRelative(m.LastSeenAt)</p>
                                    </div>
                                    <span class="text-[10px] @(m.Role == "Owner" ? "text-amber-500" : "text-zinc-600") flex-shrink-0">@m.Role</span>
                                    @if (m.Role != "Owner" && _currentUserRole == "Owner")
                                    {
                                        <button class="text-xs text-zinc-600 hover:text-red-400 transition-colors flex-shrink-0"
                                                title="Remove" @onclick="() => KickMember(m.UserId)">✕</button>
                                        <button class="text-[10px] text-zinc-600 hover:text-amber-400 transition-colors flex-shrink-0"
                                                title="Transfer ownership" @onclick="() => TransferOwnership(m.UserId)">
                                            →Owner
                                        </button>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    @if (_memberError is not null) { <p class="mt-2 text-xs text-red-400">@_memberError</p> }
                </section>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? BoardId { get; set; }
    [Parameter] public string? CurrentUserId { get; set; }
    [Parameter] public EventCallback OnClosed { get; set; }

    List<BoardMemberDto> _members = [];
    BoardInviteDto? _invite;
    string? _currentUserRole;
    bool _loadingMembers, _loadingInvite;
    string? _memberError, _inviteError;
    bool _copySuccess;

    protected override async Task OnParametersSetAsync()
    {
        if (!BoardId.HasValue) return;
        _members = [];
        _invite = null;
        _memberError = null;
        _inviteError = null;
        await Task.WhenAll(LoadMembers(), LoadInvite());
    }

    async Task LoadMembers()
    {
        _loadingMembers = true;
        try
        {
            _members = await Http.GetFromJsonAsync<List<BoardMemberDto>>(
                $"/api/boards/{BoardId}/members") ?? [];
            _currentUserRole = _members.FirstOrDefault(m => m.UserId == CurrentUserId)?.Role;
        }
        catch { _members = []; }
        _loadingMembers = false;
    }

    async Task LoadInvite()
    {
        _loadingInvite = true;
        try
        {
            var resp = await Http.GetAsync($"/api/boards/{BoardId}/invite");
            _invite = resp.IsSuccessStatusCode
                ? await resp.Content.ReadFromJsonAsync<BoardInviteDto>()
                : null;
        }
        catch { _invite = null; }
        _loadingInvite = false;
    }

    async Task GenerateInvite()
    {
        _inviteError = null;
        var resp = await Http.PostAsJsonAsync($"/api/boards/{BoardId}/invite",
            new GenerateInviteRequest(null, null));
        if (resp.IsSuccessStatusCode)
            _invite = await resp.Content.ReadFromJsonAsync<BoardInviteDto>();
        else
            _inviteError = $"Failed ({(int)resp.StatusCode})";
    }

    async Task RevokeInvite()
    {
        await Http.DeleteAsync($"/api/boards/{BoardId}/invite");
        _invite = null;
    }

    async Task CopyInviteCode()
    {
        if (_invite is null) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _invite.Code);
        _copySuccess = true;
        StateHasChanged();
        await Task.Delay(2000);
        _copySuccess = false;
        StateHasChanged();
    }

    async Task KickMember(string userId)
    {
        _memberError = null;
        var resp = await Http.DeleteAsync($"/api/boards/{BoardId}/members/{userId}");
        if (resp.IsSuccessStatusCode)
            _members.RemoveAll(m => m.UserId == userId);
        else
            _memberError = $"Could not remove ({(int)resp.StatusCode})";
    }

    async Task TransferOwnership(string newOwnerId)
    {
        _memberError = null;
        var resp = await Http.PostAsJsonAsync($"/api/boards/{BoardId}/transfer",
            new TransferOwnershipRequest(newOwnerId));
        if (resp.IsSuccessStatusCode)
            await LoadMembers();
        else
            _memberError = $"Transfer failed ({(int)resp.StatusCode})";
    }

    static string FormatRelative(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 2) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("dd MMM");
    }

    async Task Close() => await OnClosed.InvokeAsync();
}
